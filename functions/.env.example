# Cloud Functions (codebase greenmotion_web) — set these on the deployed service (Firebase Console → Functions →
# your function / Environment, or Google Cloud Run env for the service). Never commit real secrets.
#
# --- ERPX-branded mail (username reminder + password reset) ---
# Without RECOVERY_SMTP_HOST (or SMTP_HOST / MAIL_HOST), sendCustomPasswordResetEmail fails with smtp_not_configured
# and the web/iOS apps fall back to Firebase’s built-in reset email (subject/body still show the project id unless
# you set “Public-facing name” to ERPX under Project settings → General).
#
# Gmail example:
# RECOVERY_SMTP_HOST=smtp.gmail.com
# RECOVERY_SMTP_PORT=587
# RECOVERY_SMTP_SECURE=false
# RECOVERY_SMTP_USER=your-account@gmail.com
# RECOVERY_SMTP_PASS=your-app-password
# RECOVERY_SMTP_FROM="ERPX <your-account@gmail.com>"
#
# Optional: where the user lands after completing reset (Auth handler):
# PASSWORD_RESET_CONTINUE_URL=https://vehiclesentinel.com
# APP_LOGIN_URL=https://vehiclesentinel.com
#
# Alternative env names supported in code: SMTP_HOST, SMTP_PORT, SMTP_USER, SMTP_PASS, SMTP_FROM, MAIL_HOST

RECOVERY_SMTP_HOST=smtp.gmail.com
RECOVERY_SMTP_PORT=587
RECOVERY_SMTP_SECURE=false
RECOVERY_SMTP_USER=your-account@gmail.com
RECOVERY_SMTP_PASS=your-app-password
RECOVERY_SMTP_FROM="ERPX <your-account@gmail.com>"

# --- Stripe Financial (chargebacks + mail-order products) — server only ---
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...

# --- Stripe webhook (stripeFinancialWebhook function) ---
# Signing secret from Stripe Dashboard → Developers → Webhooks → your endpoint.
# Until set, the endpoint returns 503 and ignores events (deploys still work).
# STRIPE_CH_WEBHOOK_SECRET=whsec_...

# --- Optional: pin Stripe API version for all server-side REST calls ---
# Unset = account default. Pin deliberately before relying on version-specific
# behavior (e.g. 2025-03-31.basil changed partial capture/cancel refunds).
# STRIPE_API_VERSION=2025-02-24.acacia
