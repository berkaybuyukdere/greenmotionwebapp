    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^13.5.0",
    "chart.js": "^4.5.1",
    "date-fns": "^4.1.0",
    "docx": "^9.5.1",
    "docx-preview": "^0.3.7",
    "dompurify": "^3.3.3",
    "firebase": "^12.4.0",
    "framer-motion": "^11.11.17",
    "fuse.js": "^7.0.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^3.0.3",
    "jspdf-autotable": "^5.0.2",
    "jszip": "^3.10.1",
    "lucide-react": "^0.545.0",
    "mammoth": "^1.11.0",
    "pdf-lib": "^1.17.1",
    "pizzip": "^3.2.0",
    "react": "^19.2.0",
