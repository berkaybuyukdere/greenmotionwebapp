// Utility Functions
const formatDate = (timestamp) => {
    if (!timestamp) return 'N/A';
    // Handle Firestore Timestamp, number (Unix timestamp), or Date object
    let date;
    if (timestamp.seconds) {
        date = new Date(timestamp.seconds * 1000);
    } else if (typeof timestamp === 'number') {
        // iOS uses TimeInterval (seconds since 2001-01-01)
        // Convert to milliseconds since 1970
        const millisSince2001 = timestamp * 1000;
        const referenceDateMillis = new Date('2001-01-01T00:00:00Z').getTime();
        date = new Date(referenceDateMillis + millisSince2001);
    } else {
        date = new Date(timestamp);
    }
    return date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
};

const formatDateTime = (timestamp) => {
    if (!timestamp) return 'N/A';
    // Handle Firestore Timestamp, number (Unix timestamp), or Date object
    let date;
    if (timestamp.seconds) {
        date = new Date(timestamp.seconds * 1000);
    } else if (typeof timestamp === 'number') {
        // iOS uses TimeInterval (seconds since 2001-01-01)
        const millisSince2001 = timestamp * 1000;
        const referenceDateMillis = new Date('2001-01-01T00:00:00Z').getTime();
        date = new Date(referenceDateMillis + millisSince2001);
    } else {
        date = new Date(timestamp);
    }
    return date.toLocaleString('en-US', { 
        year: 'numeric', month: 'short', day: 'numeric',
        hour: '2-digit', minute: '2-digit'
    });
};

const formatCurrency = (amount) => {
    return new Intl.NumberFormat('en-CH', { style: 'currency', currency: 'CHF' }).format(amount || 0);
};

// PDF Generation Helper Functions
const loadImageAsDataURL = (url, addTimestamp = true) => {
    return new Promise((resolve, reject) => {
        const img = new Image();
        img.crossOrigin = 'Anonymous';
        img.onload = () => {
            const canvas = document.createElement('canvas');
            canvas.width = img.width;
            canvas.height = img.height;
            const ctx = canvas.getContext('2d');
            ctx.drawImage(img, 0, 0);
            
            // Add timestamp watermark if requested
            if (addTimestamp) {
                const timestamp = format(new Date(), 'dd.MM.yyyy HH:mm:ss');
                const padding = 10;
                const fontSize = Math.max(16, canvas.width * 0.03);
                
                ctx.font = `bold ${fontSize}px Arial`;
                ctx.textBaseline = 'bottom';
                
                // Measure text
                const textMetrics = ctx.measureText(timestamp);
                const textWidth = textMetrics.width;
                const textHeight = fontSize * 1.2;
                
                // Position at bottom-right
                const x = canvas.width - textWidth - padding;
                const y = canvas.height - padding;
                
                // Draw red text (no background as requested)
                ctx.fillStyle = '#EF4444';
                ctx.shadowColor = 'rgba(0, 0, 0, 0.8)';
                ctx.shadowBlur = 4;
                ctx.shadowOffsetX = 1;
                ctx.shadowOffsetY = 1;
                ctx.fillText(timestamp, x, y);
            }
            
            resolve(canvas.toDataURL('image/jpeg', 0.8));
        };
        img.onerror = () => resolve(null);
        img.src = url;
    });
};

const generateDamagePDF = async (car) => {
    const pdf = new jsPDF();
    const pageWidth = pdf.internal.pageSize.getWidth();
    const pageHeight = pdf.internal.pageSize.getHeight();
    
    // Professional Header with Blue Background
    pdf.setFillColor(37, 99, 235); // Blue
    pdf.rect(0, 0, pageWidth, 40, 'F');
    pdf.setTextColor(255, 255, 255);
    pdf.setFontSize(24);
    pdf.setFont('helvetica', 'bold');
    pdf.text('GREEN MOTION AG', pageWidth / 2, 18, { align: 'center' });
    pdf.setFontSize(14);
    pdf.setFont('helvetica', 'normal');
    pdf.text('Vehicle Damage Report', pageWidth / 2, 30, { align: 'center' });
    
    // Reset text color
    pdf.setTextColor(0, 0, 0);
    
    // Vehicle Info Table using autoTable
    pdf.autoTable({
        startY: 50,
        head: [['Vehicle Information', '']],
        body: [
            ['License Plate', car.plaka || 'N/A'],
            ['Brand', car.marka || 'N/A'],
            ['Model', car.model || 'N/A'],
            ['Category', car.kategori || 'N/A'],
            ['Color', car.renk || 'N/A'],
            ['KM', car.km || 'N/A'],
            ['Report Date', format(new Date(), 'dd.MM.yyyy HH:mm')]
        ],
        theme: 'grid',
        headStyles: { fillColor: [37, 99, 235], fontSize: 12, fontStyle: 'bold' },
        styles: { fontSize: 10, cellPadding: 5 },
        columnStyles: { 0: { fontStyle: 'bold', cellWidth: 60 }, 1: { cellWidth: 'auto' } }
    });
    
    // Get the final Y position from autoTable
    let yPosition = pdf.lastAutoTable.finalY + 15;
    
    // Damages Section
    if (car.hasarKayitlari && car.hasarKayitlari.length > 0) {
        for (let i = 0; i < car.hasarKayitlari.length; i++) {
            const hasar = car.hasarKayitlari[i];
            
            if (yPosition > pageHeight - 50) {
                pdf.addPage();
                yPosition = 20;
            }
            
            // Damage Info Table
            pdf.autoTable({
                startY: yPosition,
                head: [[`Damage Record #${i + 1}: ${hasar.resKodu || 'N/A'}`]],
                body: [
                    ['Status', hasar.durum || 'N/A'],
                    ['KM', hasar.km || 'N/A'],
                    ['Date', hasar.tarih ? formatDate(hasar.tarih) : 'N/A'],
                    ['Handover Date', hasar.handoverTarihi ? formatDate(hasar.handoverTarihi) : 'N/A']
                ],
                theme: 'striped',
                headStyles: { fillColor: [239, 68, 68], fontSize: 11, fontStyle: 'bold' },
                styles: { fontSize: 9, cellPadding: 4 },
                columnStyles: { 0: { fontStyle: 'bold', cellWidth: 40 } }
            });
            
            yPosition = pdf.lastAutoTable.finalY + 10;
            
            // Photos - 2 per row with timestamp watermarks
            if (hasar.fotograflar && hasar.fotograflar.length > 0) {
                pdf.setFontSize(11);
                pdf.setFont('helvetica', 'bold');
                pdf.setFillColor(37, 99, 235);
                pdf.setTextColor(255, 255, 255);
                pdf.rect(20, yPosition - 5, 170, 8, 'F');
                pdf.text(`Damage Photos (${hasar.fotograflar.length})`, 22, yPosition);
                pdf.setTextColor(0, 0, 0);
                yPosition += 8;
                
                const photoSize = 75;
                const margin = 8;
                let xPosition = 20;
                let photosInRow = 0;
                
                for (const photoUrl of hasar.fotograflar) {
                    if (yPosition + photoSize > pageHeight - 15) {
                        pdf.addPage();
                        yPosition = 20;
                        xPosition = 20;
                        photosInRow = 0;
                    }
                    
                    try {
                        // Load image with timestamp watermark
                        const dataUrl = await loadImageAsDataURL(photoUrl, true);
                        if (dataUrl) {
                            // Draw border
                            pdf.setDrawColor(200, 200, 200);
                            pdf.setLineWidth(0.5);
                            pdf.rect(xPosition, yPosition, photoSize, photoSize);
                            
                            // Add image
                            pdf.addImage(dataUrl, 'JPEG', xPosition + 1, yPosition + 1, photoSize - 2, photoSize - 2);
                            photosInRow++;
                            
                            if (photosInRow === 2) {
                                yPosition += photoSize + margin;
                                xPosition = 20;
                                photosInRow = 0;
                            } else {
                                xPosition += photoSize + margin;
                            }
                        }
                    } catch (error) {
                        console.error('Error loading image:', error);
                    }
                }
                
                if (photosInRow > 0) {
                    yPosition += photoSize + margin;
                }
            }
            
            yPosition += 5;
        }
    } else {
        pdf.setFont('helvetica', 'normal');
        pdf.setFontSize(10);
        pdf.text('No damages recorded', 20, yPosition);
    }
    
    // Footer
    pdf.setFontSize(8);
    pdf.setFont('helvetica', 'italic');
    pdf.text('Generated by Green Motion System', pageWidth / 2, pageHeight - 10, { align: 'center' });
    
    pdf.save(`Damage_Report_${car.plaka}_${Date.now()}.pdf`);
};

const generateOfficePDF = async (operations) => {
    const pdf = new jsPDF();
    const pageWidth = pdf.internal.pageSize.getWidth();
    
    // Professional Header
    pdf.setFillColor(34, 197, 94); // Green
    pdf.rect(0, 0, pageWidth, 40, 'F');
    pdf.setTextColor(255, 255, 255);
    pdf.setFontSize(24);
    pdf.setFont('helvetica', 'bold');
    pdf.text('GREEN MOTION AG', pageWidth / 2, 18, { align: 'center' });
    pdf.setFontSize(14);
    pdf.text('Office Operations Report', pageWidth / 2, 30, { align: 'center' });
    pdf.setTextColor(0, 0, 0);
    
    // Financial Summary
    const totals = {
        creditCard: operations.filter(op => op.type === 'Credit Card Receipt').reduce((sum, op) => sum + (op.amount || 0), 0),
        pos: operations.filter(op => op.type === 'POS Daily Closing').reduce((sum, op) => sum + (op.amount || 0), 0),
        fuel: operations.filter(op => op.type === 'Fuel Receipt').reduce((sum, op) => sum + (op.amount || 0), 0),
        washing: operations.filter(op => op.type === 'Washing Expense').reduce((sum, op) => sum + (op.amount || 0), 0)
    };
    const total = Object.values(totals).reduce((a, b) => a + b, 0);
    
    pdf.autoTable({
        startY: 50,
        head: [['Financial Summary', '']],
        body: [
            ['Total Amount', formatCurrency(total)],
            ['Credit Card', formatCurrency(totals.creditCard)],
            ['POS Closing', formatCurrency(totals.pos)],
            ['Fuel Receipt', formatCurrency(totals.fuel)],
            ['Washing Expense', formatCurrency(totals.washing)],
            ['Report Date', format(new Date(), 'dd.MM.yyyy HH:mm')]
        ],
        theme: 'grid',
        headStyles: { fillColor: [34, 197, 94], fontSize: 12, fontStyle: 'bold' },
        styles: { fontSize: 10, cellPadding: 5 },
        columnStyles: { 0: { fontStyle: 'bold', cellWidth: 60 }, 1: { cellWidth: 'auto', halign: 'right' } }
    });
    
    // Operations Table
    if (operations && operations.length > 0) {
        const tableData = operations.map(op => [
            op.type || 'N/A',
            formatCurrency(op.amount || 0),
            op.date ? formatDate(op.date) : 'N/A',
            op.vehiclePlate || '-',
            op.notes || '-'
        ]);
        
        pdf.autoTable({
            startY: pdf.lastAutoTable.finalY + 10,
            head: [['Type', 'Amount', 'Date', 'Vehicle', 'Notes']],
            body: tableData,
            theme: 'striped',
            headStyles: { fillColor: [34, 197, 94], fontSize: 10, fontStyle: 'bold' },
            styles: { fontSize: 8, cellPadding: 4 },
            columnStyles: {
                0: { cellWidth: 35 },
                1: { cellWidth: 25, halign: 'right' },
                2: { cellWidth: 30 },
                3: { cellWidth: 25 },
                4: { cellWidth: 'auto' }
            }
        });
        
        // Add photos if any operation has photos
        for (const op of operations) {
            if (op.photos && op.photos.length > 0) {
                let yPos = pdf.lastAutoTable.finalY + 10;
                pdf.setFontSize(10);
                pdf.setFont('helvetica', 'bold');
                pdf.text(`Photos for ${op.type} (${op.date ? formatDate(op.date) : 'N/A'}):`, 20, yPos);
                yPos += 8;
                
                const photoSize = 60;
                const margin = 8;
                let xPos = 20;
                let photosInRow = 0;
                
                for (const photoUrl of op.photos) {
                    try {
                        const dataUrl = await loadImageAsDataURL(photoUrl, true);
                        if (dataUrl) {
                            pdf.setDrawColor(200, 200, 200);
                            pdf.rect(xPos, yPos, photoSize, photoSize);
                            pdf.addImage(dataUrl, 'JPEG', xPos + 1, yPos + 1, photoSize - 2, photoSize - 2);
                            photosInRow++;
                            
                            if (photosInRow === 3) {
                                yPos += photoSize + margin;
                                xPos = 20;
                                photosInRow = 0;
                            } else {
                                xPos += photoSize + margin;
                            }
                        }
                    } catch (error) {
                        console.error('Error loading image:', error);
                    }
                }
            }
        }
    }
    
    pdf.save(`Office_Operations_${format(new Date(), 'yyyyMMdd_HHmmss')}.pdf`);
};

