                </div>
                
                <div className="bg-gradient-to-br from-purple-500 to-purple-600 rounded-2xl p-6 text-white shadow-lg">
                    <div className="flex items-center justify-between">
                        <div>
                            <p className="text-purple-100 text-sm font-medium">Total Returns</p>
                            <p className="text-4xl font-bold mt-2">{returns.length}</p>
                        </div>
                        <ArrowLeft className="opacity-30" size={48} />
                    </div>
                </div>
            </div>
            
            {/* Financial Summary */}
            <div className="bg-white rounded-2xl border border-gray-200 p-6 shadow-sm">
                <h2 className="text-xl font-bold text-gray-900 mb-4 flex items-center gap-2">
                    <DollarSign className="text-green-600" size={24} />
                    Financial Summary
                </h2>
                <div className="grid grid-cols-2 md:grid-cols-5 gap-4">
                    <div className="bg-gradient-to-br from-blue-50 to-blue-100 rounded-xl p-4">
                        <p className="text-xs text-blue-600 font-medium">Total Expenses</p>
                        <p className="text-2xl font-bold text-blue-700 mt-1">{formatCurrency(totalOfficeExpenses)}</p>
                    </div>
                    <div className="bg-gradient-to-br from-green-50 to-green-100 rounded-xl p-4">
                        <p className="text-xs text-green-600 font-medium">Service Costs</p>
                        <p className="text-2xl font-bold text-green-700 mt-1">{formatCurrency(totalServiceCost)}</p>
                    </div>
                    <div className="bg-gradient-to-br from-yellow-50 to-yellow-100 rounded-xl p-4">
                        <p className="text-xs text-yellow-600 font-medium">Fuel Expenses</p>
                        <p className="text-2xl font-bold text-yellow-700 mt-1">{formatCurrency(fuelExpenses)}</p>
                    </div>
                    <div className="bg-gradient-to-br from-cyan-50 to-cyan-100 rounded-xl p-4">
                        <p className="text-xs text-cyan-600 font-medium">Washing</p>
                        <p className="text-2xl font-bold text-cyan-700 mt-1">{formatCurrency(washingExpenses)}</p>
                    </div>
                    <div className="bg-gradient-to-br from-purple-50 to-purple-100 rounded-xl p-4">
                        <p className="text-xs text-purple-600 font-medium">POS Closing</p>
