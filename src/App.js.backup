                    <h3 className="text-lg font-bold text-gray-900 mb-4 flex items-center gap-2">
                        <PieChartIcon className="text-blue-600" size={20} />
                        Vehicle Distribution by Category
                    </h3>
                    <div style={{ height: '300px' }}>
                        <Doughnut data={categoryData} options={chartOptions} />
                    </div>
                </div>
                
                {/* Expense Types */}
                <div className="bg-white rounded-2xl border border-gray-200 p-6 shadow-sm">
                    <h3 className="text-lg font-bold text-gray-900 mb-4 flex items-center gap-2">
                        <BarChart3 className="text-green-600" size={20} />
                        Expenses by Type
                    </h3>
                    <div style={{ height: '300px' }}>
                        <Bar data={expenseTypeData} options={{...chartOptions, plugins: {...chartOptions.plugins, legend: {display: false}}}} />
                    </div>
                </div>
                
                {/* Damage Status */}
                <div className="bg-white rounded-2xl border border-gray-200 p-6 shadow-sm">
                    <h3 className="text-lg font-bold text-gray-900 mb-4 flex items-center gap-2">
                        <AlertCircle className="text-red-600" size={20} />
                        Damage Status Overview
                    </h3>
                    <div style={{ height: '300px' }}>
                        <Pie data={damagesByStatus} options={chartOptions} />
                    </div>
                </div>
                
                {/* Service Status */}
                <div className="bg-white rounded-2xl border border-gray-200 p-6 shadow-sm">
                    <h3 className="text-lg font-bold text-gray-900 mb-4 flex items-center gap-2">
                        <Package className="text-purple-600" size={20} />
                        Service Status
                    </h3>
                    <div style={{ height: '300px' }}>
                        <Doughnut data={serviceStatusData} options={chartOptions} />
                    </div>
                </div>
            </div>
            
            {/* Detailed Statistics Table */}
            <div className="bg-white rounded-2xl border border-gray-200 p-6 shadow-sm">
                <h3 className="text-lg font-bold text-gray-900 mb-4 flex items-center gap-2">
                    <TrendingUp className="text-blue-600" size={20} />
