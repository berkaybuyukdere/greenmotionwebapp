}

// OCR SCAN VIEW Component
function ScanView({ addActivity }) {
    const [uploadedFile, setUploadedFile] = useState(null);
    const [fileType, setFileType] = useState(null);
    const [extractedText, setExtractedText] = useState('');
    const [editableText, setEditableText] = useState('');
    const [loading, setLoading] = useState(false);
    const [progress, setProgress] = useState(0);
    const [replacements, setReplacements] = useState([{ find: '', replace: '' }]);
    
    const handleFileUpload = async (e) => {
        const file = e.target.files[0];
        if (!file) return;
        
        const fileExt = file.name.split('.').pop().toLowerCase();
        if (!['pdf', 'doc', 'docx'].includes(fileExt)) {
            alert('Please upload PDF or Word documents only');
            return;
        }
        
        setUploadedFile(file);
        setFileType(fileExt);
        setExtractedText('');
        setEditableText('');
        setProgress(0);
    };
    
    const extractTextFromPDF = async (file) => {
        try {
            setLoading(true);
            setProgress(10);
            
            const arrayBuffer = await file.arrayBuffer();
            const pdfDoc = await PDFDocument.load(arrayBuffer);
            const pages = pdfDoc.getPages();
            
            let fullText = '';
            
            for (let i = 0; i < pages.length; i++) {
                setProgress(10 + (i / pages.length) * 70);
                
                // Convert PDF page to image for OCR
                const canvas = document.createElement('canvas');
                const context = canvas.getContext('2d');
                
                // For OCR, we need to render the page as image
                // This is a simplified approach - in production, use pdf.js
                fullText += `\n--- Page ${i + 1} ---\n`;
            }
            
            // Use Tesseract for OCR if needed
            setProgress(80);
            
            // For now, extract text fields
            const form = pdfDoc.getForm();
            const fields = form.getFields();
            fields.forEach(field => {
                const name = field.getName();
                const value = field.constructor.name.includes('Text') ? field.getText() : '';
                if (value) fullText += `${name}: ${value}\n`;
            });
            
            setProgress(100);
            return fullText || 'No text found in PDF. Try uploading an image-based PDF for OCR.';
        } catch (error) {
            console.error('Error extracting PDF:', error);
            return 'Error extracting text from PDF: ' + error.message;
        }
    };
    
    const extractTextFromWord = async (file) => {
        try {
            setLoading(true);
            setProgress(30);
            
            const arrayBuffer = await file.arrayBuffer();
            const result = await mammoth.extractRawText({ arrayBuffer });
            
            setProgress(100);
            return result.value || 'No text found in Word document.';
        } catch (error) {
            console.error('Error extracting Word:', error);
            return 'Error extracting text from Word: ' + error.message;
        }
    };
    
    const performOCR = async () => {
        if (!uploadedFile) {
            alert('Please upload a file first');
            return;
        }
        
        setLoading(true);
        
        try {
            let text = '';
            
            if (fileType === 'pdf') {
                text = await extractTextFromPDF(uploadedFile);
            } else if (fileType === 'doc' || fileType === 'docx') {
                text = await extractTextFromWord(uploadedFile);
            }
            
            setExtractedText(text);
            setEditableText(text);
            addActivity('OCR Scan Completed', `Scanned ${uploadedFile.name}`);
        } catch (error) {
            alert('Error processing file: ' + error.message);
        } finally {
            setLoading(false);
        }
    };
    
    const addReplacement = () => {
        setReplacements([...replacements, { find: '', replace: '' }]);
    };
    
    const updateReplacement = (index, field, value) => {
        const updated = [...replacements];
        updated[index][field] = value;
        setReplacements(updated);
    };
    
    const removeReplacement = (index) => {
        setReplacements(replacements.filter((_, i) => i !== index));
    };
    
    const applyReplacements = () => {
        let newText = extractedText;
        
        replacements.forEach(({ find, replace }) => {
            if (find) {
                const regex = new RegExp(find, 'g');
                newText = newText.replace(regex, replace);
            }
        });
        
        setEditableText(newText);
        addActivity('Text Replacements Applied', `Applied ${replacements.filter(r => r.find).length} replacements`);
    };
    
    const exportDocument = async () => {
        if (!editableText) {
            alert('No text to export');
            return;
        }
        
        try {
            if (fileType === 'pdf') {
                // Export as PDF
                const pdf = new jsPDF();
                const pageWidth = pdf.internal.pageSize.getWidth();
                const lines = pdf.splitTextToSize(editableText, pageWidth - 40);
                
                let y = 20;
                lines.forEach(line => {
                    if (y > 280) {
                        pdf.addPage();
                        y = 20;
                    }
                    pdf.text(line, 20, y);
                    y += 7;
                });
                
                pdf.save(`edited_${uploadedFile.name}.pdf`);
            } else {
                // Export as Word
                const paragraphs = editableText.split('\n').map(line => 
                    new Paragraph({
                        children: [new TextRun(line)]
                    })
                );
                
                const doc = new Document({
                    sections: [{ children: paragraphs }]
                });
                
                const blob = await Packer.toBlob(doc);
                const url = URL.createObjectURL(blob);
                const a = document.createElement('a');
                a.href = url;
                a.download = `edited_${uploadedFile.name}`;
                a.click();
                URL.revokeObjectURL(url);
            }
            
            addActivity('Document Exported', `Exported edited ${uploadedFile.name}`);
        } catch (error) {
            alert('Error exporting document: ' + error.message);
        }
    };
    
    return (
        <div className="space-y-6">
            <div className="flex items-center justify-between">
                <div>
                    <h1 className="text-3xl font-bold text-gray-900">OCR Document Scanner</h1>
                    <p className="text-gray-600 mt-1">Upload, scan, edit and export PDF/Word documents</p>
                </div>
            </div>
            
            {/* Upload Section */}
            <div className="bg-white rounded-2xl border border-gray-200 p-6 shadow-sm">
                <h2 className="text-xl font-bold text-gray-900 mb-4 flex items-center gap-2">
                    <Upload className="text-blue-600" size={24} />
                    Upload Document
                </h2>
                
                <div className="border-2 border-dashed border-gray-300 rounded-xl p-8 text-center hover:border-blue-500 transition-all">
                    <input 
                        type="file" 
                        accept=".pdf,.doc,.docx" 
                        onChange={handleFileUpload}
                        className="hidden"
                        id="fileUpload"
                    />
                    <label htmlFor="fileUpload" className="cursor-pointer">
                        <FileType className="mx-auto text-gray-400 mb-4" size={48} />
                        <p className="text-lg font-medium text-gray-700">Click to upload PDF or Word document</p>
                        <p className="text-sm text-gray-500 mt-2">Supports: .pdf, .doc, .docx</p>
                    </label>
                </div>
                
                {uploadedFile && (
                    <div className="mt-4 p-4 bg-blue-50 rounded-xl flex items-center justify-between">
                        <div className="flex items-center gap-3">
                            <FileText className="text-blue-600" size={24} />
                            <div>
                                <p className="font-medium text-gray-900">{uploadedFile.name}</p>
                                <p className="text-sm text-gray-600">{(uploadedFile.size / 1024).toFixed(2)} KB</p>
                            </div>
                        </div>
                        <button 
                            onClick={performOCR}
                            disabled={loading}
                            className="flex items-center gap-2 px-6 py-3 bg-gradient-to-r from-blue-500 to-blue-600 hover:from-blue-600 hover:to-blue-700 text-white rounded-xl transition-all shadow-lg disabled:opacity-50"
                        >
                            <Scan size={20} />
                            {loading ? 'Processing...' : 'Extract Text'}
                        </button>
                    </div>
                )}
                
                {loading && (
                    <div className="mt-4">
                        <div className="w-full bg-gray-200 rounded-full h-3">
                            <div 
                                className="bg-blue-600 h-3 rounded-full transition-all duration-300"
                                style={{ width: `${progress}%` }}
                            ></div>
                        </div>
                        <p className="text-center text-sm text-gray-600 mt-2">{progress}% Complete</p>
                    </div>
                )}
            </div>
            
            {/* Text Replacement Section */}
            {extractedText && (
                <div className="bg-white rounded-2xl border border-gray-200 p-6 shadow-sm">
                    <h2 className="text-xl font-bold text-gray-900 mb-4 flex items-center gap-2">
                        <RefreshCw className="text-green-600" size={24} />
                        Find & Replace
                    </h2>
                    
                    <div className="space-y-3">
                        {replacements.map((replacement, index) => (
                            <div key={index} className="flex items-center gap-3">
                                <input 
                                    type="text"
                                    placeholder="Find text..."
                                    value={replacement.find}
                                    onChange={(e) => updateReplacement(index, 'find', e.target.value)}
                                    className="flex-1 px-4 py-2 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500"
                                />
                                <span className="text-gray-500">→</span>
                                <input 
                                    type="text"
                                    placeholder="Replace with..."
                                    value={replacement.replace}
                                    onChange={(e) => updateReplacement(index, 'replace', e.target.value)}
                                    className="flex-1 px-4 py-2 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500"
                                />
                                <button 
                                    onClick={() => removeReplacement(index)}
                                    className="p-2 text-red-600 hover:bg-red-50 rounded-xl transition-all"
                                >
                                    <Trash2 size={20} />
                                </button>
                            </div>
                        ))}
                    </div>
                    
                    <div className="flex gap-3 mt-4">
                        <button 
                            onClick={addReplacement}
                            className="flex items-center gap-2 px-4 py-2 bg-gray-100 hover:bg-gray-200 rounded-xl transition-all"
                        >
                            <Plus size={18} />
                            Add Rule
                        </button>
                        <button 
                            onClick={applyReplacements}
                            className="flex items-center gap-2 px-6 py-2 bg-gradient-to-r from-green-500 to-green-600 hover:from-green-600 hover:to-green-700 text-white rounded-xl transition-all shadow-lg"
                        >
                            <RefreshCw size={18} />
                            Apply Replacements
                        </button>
                    </div>
                </div>
            )}
            
            {/* Extracted Text Display */}
            {extractedText && (
                <div className="grid grid-cols-1 lg:grid-cols-2 gap-6">
                    <div className="bg-white rounded-2xl border border-gray-200 p-6 shadow-sm">
                        <h3 className="text-lg font-bold text-gray-900 mb-4">Original Text</h3>
                        <div className="bg-gray-50 rounded-xl p-4 h-96 overflow-y-auto">
                            <pre className="text-sm text-gray-700 whitespace-pre-wrap font-mono">{extractedText}</pre>
                        </div>
                    </div>
                    
                    <div className="bg-white rounded-2xl border border-gray-200 p-6 shadow-sm">
                        <div className="flex items-center justify-between mb-4">
                            <h3 className="text-lg font-bold text-gray-900">Edited Text</h3>
                            <button 
                                onClick={exportDocument}
                                className="flex items-center gap-2 px-4 py-2 bg-gradient-to-r from-purple-500 to-purple-600 hover:from-purple-600 hover:to-purple-700 text-white rounded-xl transition-all shadow-lg text-sm"
                            >
                                <Download size={18} />
                                Export
                            </button>
                        </div>
                        <textarea 
                            value={editableText}
                            onChange={(e) => setEditableText(e.target.value)}
                            className="w-full h-96 bg-gray-50 rounded-xl p-4 text-sm text-gray-700 font-mono focus:outline-none focus:ring-2 focus:ring-purple-500 resize-none"
                        />
                    </div>
                </div>
            )}
            
            {!extractedText && !loading && (
                <div className="bg-gradient-to-br from-blue-50 to-purple-50 rounded-2xl border border-blue-200 p-12 text-center">
                    <Scan className="mx-auto text-blue-400 mb-4" size={64} />
                    <h3 className="text-xl font-bold text-gray-900 mb-2">No Document Scanned</h3>
                    <p className="text-gray-600">Upload a PDF or Word document to get started with OCR scanning</p>
                </div>
            )}
        </div>
    );
}

// CARS VIEW Component
function CarsView({ cars, onRefresh, addActivity }) {
    const [showAddModal, setShowAddModal] = useState(false);
    const [showDetailModal, setShowDetailModal] = useState(false);
    const [selectedCar, setSelectedCar] = useState(null);
    const [searchQuery, setSearchQuery] = useState('');
    const [filterCategory, setFilterCategory] = useState('all');
    const [filterStatus, setFilterStatus] = useState('all');
    const [viewMode, setViewMode] = useState('list'); // 'grid' or 'list' - DEFAULT: list

    const categories = ['A','B','D','F','H','J','L','M','MB','MC','N','R','S','T','U','V','X','Y','Z'];

    const filteredCars = cars.filter(car => {
        const query = searchQuery.toLowerCase();
        const matchesSearch = car.plaka?.toLowerCase().includes(query) || 
                             car.marka?.toLowerCase().includes(query) ||
                             car.model?.toLowerCase().includes(query) ||
                             car.hasarKayitlari?.some(h => h.resKodu?.toLowerCase().includes(query));
        const matchesCategory = filterCategory === 'all' || car.kategori === filterCategory;
        const matchesStatus = filterStatus === 'all' || 
                             (filterStatus === 'damaged' && car.hasarKayitlari?.length > 0) ||
                             (filterStatus === 'clean' && (!car.hasarKayitlari || car.hasarKayitlari.length === 0));
        return matchesSearch && matchesCategory && matchesStatus;
    });

    return (
        <div className="space-y-6">
            <div className="flex items-center justify-between gap-4 flex-wrap">
                <div>
                    <h2 className="text-4xl font-bold text-gray-900 flex items-center gap-3">
                        <Car className="text-blue-500" size={36} />
                        Vehicles
                    </h2>
                    <p className="text-gray-500 mt-1">{filteredCars.length} of {cars.length} vehicles</p>
                </div>
                <div className="flex items-center gap-3">
                    <div className="flex bg-gray-100 rounded-xl p-1 border border-gray-200">
                        <button 
                            onClick={() => setViewMode('grid')}
                            className={`px-4 py-2 rounded-lg flex items-center gap-2 transition-all ${viewMode === 'grid' ? 'bg-white shadow text-blue-600' : 'text-gray-600 hover:text-gray-900'}`}>
                            <Grid size={18} />
                            <span className="font-medium">Grid</span>
                        </button>
                        <button 
                            onClick={() => setViewMode('list')}
                            className={`px-4 py-2 rounded-lg flex items-center gap-2 transition-all ${viewMode === 'list' ? 'bg-white shadow text-blue-600' : 'text-gray-600 hover:text-gray-900'}`}>
                            <List size={18} />
                            <span className="font-medium">List</span>
                        </button>
                    </div>
                    <button onClick={() => setShowAddModal(true)} 
                            className="flex items-center gap-2 px-6 py-3 bg-gradient-to-r from-blue-500 to-blue-600 hover:from-blue-600 hover:to-blue-700 text-white rounded-xl transition-all shadow-lg shadow-blue-500/30 font-medium">
                        <Plus size={20} />Add Vehicle
                    </button>
                </div>
            </div>

            <div className="bg-white rounded-2xl shadow-lg border border-gray-200 p-6">
                <div className="grid grid-cols-1 md:grid-cols-3 gap-4">
                    <div className="relative">
                        <Search className="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400" size={20} />
                        <input
                            type="text"
                            value={searchQuery}
                            onChange={(e) => setSearchQuery(e.target.value)}
                            placeholder="Search by plate, brand, model, or RES code..."
                            className="w-full pl-10 pr-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 focus:outline-none focus:ring-2 focus:ring-blue-500"
                        />
                    </div>
                    <select value={filterCategory} onChange={(e) => setFilterCategory(e.target.value)}
                            className="px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 focus:outline-none focus:ring-2 focus:ring-blue-500">
                        <option value="all">All Categories</option>
                        {categories.map(c => <option key={c} value={c}>Category {c}</option>)}
                    </select>
                    <select value={filterStatus} onChange={(e) => setFilterStatus(e.target.value)}
                            className="px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 focus:outline-none focus:ring-2 focus:ring-blue-500">
                        <option value="all">All Status</option>
                        <option value="damaged">Damaged</option>
                        <option value="clean">Clean</option>
                    </select>
                </div>
            </div>

            {viewMode === 'grid' ? (
                <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                    {filteredCars.map((car) => (
                        <div key={car.id} onClick={() => { setSelectedCar(car); setShowDetailModal(true); }}
                             className="bg-white rounded-2xl border border-gray-200 p-6 hover:border-blue-300 hover:shadow-2xl transition-all cursor-pointer group">
                            <div className="flex items-start justify-between mb-4">
                                <div className="flex items-center gap-3">
                                    <div className="w-14 h-14 bg-gradient-to-br from-blue-100 to-blue-50 rounded-xl flex items-center justify-center group-hover:scale-110 transition-transform">
                                        <Car className="text-blue-600" size={28} />
                                    </div>
                                    <div>
                                        <h3 className="text-xl font-bold text-gray-900">{car.plaka}</h3>
                                        <p className="text-gray-500 text-sm">{car.marka} {car.model}</p>
                                    </div>
                                </div>
                                <span className="px-3 py-1 bg-blue-100 text-blue-700 text-xs font-semibold rounded-lg">
                                    {car.kategori}
                                </span>
                            </div>

                            <div className="space-y-3 text-sm">
                                <div className="flex justify-between items-center p-3 bg-gray-50 rounded-lg">
                                    <span className="text-gray-600">Damages:</span>
                                    <span className={`font-bold ${car.hasarKayitlari?.length > 0 ? 'text-orange-600' : 'text-green-600'}`}>
                                        {car.hasarKayitlari?.length || 0}
                                    </span>
                                </div>
                                <div className="flex justify-between items-center p-3 bg-gray-50 rounded-lg">
                                    <span className="text-gray-600">Photos:</span>
                                    <span className="text-gray-900 font-bold">
                                        {car.hasarKayitlari?.reduce((acc, h) => acc + (h.fotograflar?.length || 0), 0) || 0}
                                    </span>
                                </div>
                                <div className="flex justify-between items-center p-3 bg-gray-50 rounded-lg">
                                    <span className="text-gray-600">Vignette:</span>
                                    <span className={`font-bold ${car.vignetteVar ? 'text-green-600' : 'text-red-600'}`}>
                                        {car.vignetteVar ? 'Yes' : 'No'}
                                    </span>
                                </div>
                            </div>

                            <div className="mt-4 pt-4 border-t border-gray-200 flex items-center justify-between text-xs text-gray-500">
                                <span>Click to view details</span>
                                <ChevronRight size={16} />
                            </div>
                        </div>
                    ))}
                </div>
            ) : (
                <div className="bg-white rounded-2xl border border-gray-200 overflow-hidden">
                    <table className="w-full">
                        <thead className="bg-gray-50 border-b border-gray-200">
                            <tr>
                                <th className="px-6 py-4 text-left text-sm font-semibold text-gray-700">License Plate</th>
                                <th className="px-6 py-4 text-left text-sm font-semibold text-gray-700">Brand / Model</th>
                                <th className="px-6 py-4 text-left text-sm font-semibold text-gray-700">Category</th>
                                <th className="px-6 py-4 text-left text-sm font-semibold text-gray-700">Color</th>
                                <th className="px-6 py-4 text-center text-sm font-semibold text-gray-700">Damages</th>
                                <th className="px-6 py-4 text-center text-sm font-semibold text-gray-700">Photos</th>
                                <th className="px-6 py-4 text-center text-sm font-semibold text-gray-700">Vignette</th>
                                <th className="px-6 py-4 text-center text-sm font-semibold text-gray-700">Actions</th>
                            </tr>
                        </thead>
                        <tbody className="divide-y divide-gray-200">
                            {filteredCars.map((car) => (
                                <tr key={car.id} className="hover:bg-gray-50 transition-colors">
                                    <td className="px-6 py-4 font-bold text-gray-900">{car.plaka}</td>
                                    <td className="px-6 py-4 text-gray-700">{car.marka} {car.model}</td>
                                    <td className="px-6 py-4">
                                        <span className="px-3 py-1 bg-blue-100 text-blue-700 text-xs font-semibold rounded-lg">
                                            {car.kategori}
                                        </span>
                                    </td>
                                    <td className="px-6 py-4 text-gray-700">{car.renk}</td>
                                    <td className="px-6 py-4 text-center">
                                        <span className={`font-bold ${car.hasarKayitlari?.length > 0 ? 'text-orange-600' : 'text-green-600'}`}>
                                            {car.hasarKayitlari?.length || 0}
                                        </span>
                                    </td>
                                    <td className="px-6 py-4 text-center text-gray-900 font-semibold">
                                        {car.hasarKayitlari?.reduce((acc, h) => acc + (h.fotograflar?.length || 0), 0) || 0}
                                    </td>
                                    <td className="px-6 py-4 text-center">
                                        <span className={`font-bold ${car.vignetteVar ? 'text-green-600' : 'text-red-600'}`}>
                                            {car.vignetteVar ? 'Yes' : 'No'}
                                        </span>
                                    </td>
                                    <td className="px-6 py-4 text-center">
                                        <button 
                                            onClick={() => { setSelectedCar(car); setShowDetailModal(true); }}
                                            className="px-4 py-2 bg-blue-500 hover:bg-blue-600 text-white text-sm rounded-lg transition-colors flex items-center gap-2 mx-auto">
                                            <Eye size={16} />
                                            View
                                        </button>
                                    </td>
                                </tr>
                            ))}
                        </tbody>
                    </table>
                </div>
            )}

            {filteredCars.length === 0 && (
                <div className="text-center py-20 bg-white rounded-2xl border border-gray-200">
                    <Car className="mx-auto text-gray-300 mb-4" size={64} />
                    <h3 className="text-xl font-semibold text-gray-400 mb-2">No vehicles found</h3>
                    <p className="text-gray-500">Try adjusting your filters or add a new vehicle</p>
                </div>
            )}

            {showAddModal && <AddCarModal onClose={() => setShowAddModal(false)} onSuccess={() => { setShowAddModal(false); onRefresh(); addActivity('Araç Eklendi', 'New vehicle added'); }} />}
            {showDetailModal && selectedCar && <CarDetailModal car={selectedCar} onClose={() => { setShowDetailModal(false); setSelectedCar(null); }} onSuccess={() => { setShowDetailModal(false); setSelectedCar(null); onRefresh(); }} addActivity={addActivity} />}
        </div>
    );
}

function AddCarModal({ onClose, onSuccess }) {
    const [formData, setFormData] = useState({ 
        plaka: '', 
        marka: '', 
        model: '', 
        renk: '',
        kategori: 'A', 
        vignetteVar: false, 
        anahtarSayisi: 1, 
        kafaKagidiVar: false,
        km: ''
    });
    const [loading, setLoading] = useState(false);
    const categories = ['A','B','D','F','H','J','L','M','MB','MC','N','R','S','T','U','V','X','Y','Z'];

    const handleSubmit = async () => {
        if (!formData.plaka || !formData.marka || !formData.model) {
            alert('Please fill all required fields');
            return;
        }
        setLoading(true);
        try {
            await addDoc(collection(db, 'araclar'), { 
                ...formData, 
                kayitTarihi: Timestamp.now(), 
                hasarKayitlari: [], 
                qrCode: formData.plaka 
            });
            onSuccess();
        } catch (error) {
            console.error('Error:', error);
            alert('Failed to add vehicle');
        } finally {
            setLoading(false);
        }
    };

    return (
        <div className="fixed inset-0 bg-black/30 backdrop-blur-sm flex items-center justify-center p-4 z-50">
            <div className="bg-white rounded-2xl shadow-2xl border border-gray-200 p-6 w-full max-w-md">
                <div className="flex items-center justify-between mb-6">
                    <h3 className="text-2xl font-bold text-gray-900">Add New Vehicle</h3>
                    <button onClick={onClose} className="text-gray-400 hover:text-gray-600 transition-colors"><X size={24} /></button>
                </div>
                <div className="space-y-4">
                    <div>
                        <label className="block text-sm font-medium text-gray-700 mb-2">License Plate *</label>
                        <input type="text" value={formData.plaka} onChange={(e) => setFormData({ ...formData, plaka: e.target.value })} 
                               className="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 focus:outline-none focus:ring-2 focus:ring-blue-500" 
                               placeholder="ZH 123456" />
                    </div>
                    <div>
                        <label className="block text-sm font-medium text-gray-700 mb-2">Brand *</label>
                        <input type="text" value={formData.marka} onChange={(e) => setFormData({ ...formData, marka: e.target.value })} 
                               className="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 focus:outline-none focus:ring-2 focus:ring-blue-500" 
                               placeholder="BMW" />
                    </div>
                    <div>
                        <label className="block text-sm font-medium text-gray-700 mb-2">Model *</label>
                        <input type="text" value={formData.model} onChange={(e) => setFormData({ ...formData, model: e.target.value })} 
                               className="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 focus:outline-none focus:ring-2 focus:ring-blue-500" 
                               placeholder="3 Series" />
                    </div>
                    <div className="grid grid-cols-2 gap-4">
                        <div>
                            <label className="block text-sm font-medium text-gray-700 mb-2">Color</label>
                            <input type="text" value={formData.renk} onChange={(e) => setFormData({ ...formData, renk: e.target.value })} 
                                   className="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 focus:outline-none focus:ring-2 focus:ring-blue-500" 
                                   placeholder="Black" />
                        </div>
                        <div>
                            <label className="block text-sm font-medium text-gray-700 mb-2">KM</label>
                            <input type="number" value={formData.km} onChange={(e) => setFormData({ ...formData, km: e.target.value })} 
                                   className="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 focus:outline-none focus:ring-2 focus:ring-blue-500" 
                                   placeholder="50000" />
                        </div>
                    </div>
                    <div>
                        <label className="block text-sm font-medium text-gray-700 mb-2">Category</label>
                        <select value={formData.kategori} onChange={(e) => setFormData({ ...formData, kategori: e.target.value })} 
                                className="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 focus:outline-none focus:ring-2 focus:ring-blue-500">
                            {categories.map(c => <option key={c} value={c}>{c}</option>)}
                        </select>
                    </div>
                    <div>
                        <label className="block text-sm font-medium text-gray-700 mb-2 flex items-center gap-2">
                            <Key size={16} />
                            Number of Keys
                        </label>
                        <input type="number" min="0" value={formData.anahtarSayisi} onChange={(e) => setFormData({ ...formData, anahtarSayisi: parseInt(e.target.value) || 0 })} 
                               className="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 focus:outline-none focus:ring-2 focus:ring-blue-500" 
                               placeholder="1" />
                    </div>
                    <div className="space-y-3">
                        <div className="flex items-center gap-3 p-3 bg-gray-50 rounded-xl">
                            <input type="checkbox" id="vig" checked={formData.vignetteVar} onChange={(e) => setFormData({ ...formData, vignetteVar: e.target.checked })} 
                                   className="w-5 h-5 rounded border-gray-300 text-blue-600 focus:ring-blue-500" />
                            <label htmlFor="vig" className="text-gray-700 font-medium">Has Vignette</label>
                        </div>
                        <div className="flex items-center gap-3 p-3 bg-gray-50 rounded-xl">
                            <input type="checkbox" id="kafakagidi" checked={formData.kafaKagidiVar} onChange={(e) => setFormData({ ...formData, kafaKagidiVar: e.target.checked })} 
                                   className="w-5 h-5 rounded border-gray-300 text-blue-600 focus:ring-blue-500" />
                            <label htmlFor="kafakagidi" className="text-gray-700 font-medium flex items-center gap-2">
                                <FileCheck size={16} />
                                Has Kafa Kağıdı (Registration Document)
                            </label>
                        </div>
                    </div>
                    <div className="flex gap-3 pt-4">
                        <button onClick={onClose} className="flex-1 px-4 py-3 bg-gray-100 hover:bg-gray-200 text-gray-700 rounded-xl transition-colors font-medium">
                            Cancel
                        </button>
                        <button onClick={handleSubmit} disabled={loading} 
                                className="flex-1 px-4 py-3 bg-gradient-to-r from-blue-500 to-blue-600 hover:from-blue-600 hover:to-blue-700 text-white rounded-xl transition-colors shadow-lg shadow-blue-500/30 font-medium">
                            {loading ? 'Adding...' : 'Add Vehicle'}
                        </button>
                    </div>
                </div>
            </div>
        </div>
    );
}

function CarDetailModal({ car, onClose, onSuccess, addActivity }) {
    const [showAddDamage, setShowAddDamage] = useState(false);
    const [showPhotoGallery, setShowPhotoGallery] = useState(false);
    const [showReturnModal, setShowReturnModal] = useState(false);
    const [showEditModal, setShowEditModal] = useState(false);
    const [selectedPhotos, setSelectedPhotos] = useState([]);
    const [editedCar, setEditedCar] = useState(car);

    const allPhotos = car.hasarKayitlari?.flatMap(h => h.fotograflar || []) || [];

    const handleDelete = async () => {
        if (!window.confirm('Are you sure you want to delete this vehicle?')) return;
        try {
            await deleteDoc(doc(db, 'araclar', car.id));
            addActivity('Araç Silindi', `Vehicle ${car.plaka} deleted`);
            onSuccess();
        } catch (error) {
            alert('Failed to delete vehicle');
        }
    };

    const handleUpdate = async () => {
        try {
            await updateDoc(doc(db, 'araclar', car.id), editedCar);
            addActivity('Araç Güncellendi', `Vehicle ${car.plaka} updated`);
            setShowEditModal(false);
            onSuccess();
        } catch (error) {
            alert('Failed to update vehicle');
        }
    };

    const handleDeleteDamage = async (damageIndex) => {
        if (!window.confirm('Are you sure you want to delete this damage record?')) return;
        try {
            const updatedDamages = car.hasarKayitlari.filter((_, i) => i !== damageIndex);
            await updateDoc(doc(db, 'araclar', car.id), { hasarKayitlari: updatedDamages });
            addActivity('Hasar Silindi', `Damage removed from ${car.plaka}`);
            onSuccess();
        } catch (error) {
            alert('Failed to delete damage');
        }
    };

    const handleToggleDamageStatus = async (damageIndex) => {
        try {
            const updatedDamages = [...car.hasarKayitlari];
            updatedDamages[damageIndex].durum = updatedDamages[damageIndex].durum === 'In Progress' ? 'Done' : 'In Progress';
            await updateDoc(doc(db, 'araclar', car.id), { hasarKayitlari: updatedDamages });
            addActivity('Hasar Durumu Güncellendi', `Damage status updated for ${car.plaka}`);
            onSuccess();
        } catch (error) {
            alert('Failed to update damage status');
        }
    };

    return (
        <div className="fixed inset-0 bg-black/30 backdrop-blur-sm flex items-center justify-center p-4 z-50 overflow-y-auto">
            <div className="bg-white rounded-2xl shadow-2xl border border-gray-200 p-6 w-full max-w-6xl my-8">
                <div className="flex items-center justify-between mb-6">
                    <h3 className="text-2xl font-bold text-gray-900 flex items-center gap-2">
                        <Car className="text-blue-500" size={28} />
                        Vehicle Details
                    </h3>
                    <button onClick={onClose} className="text-gray-400 hover:text-gray-600 transition-colors">
                        <X size={24} />
                    </button>
                </div>

                <div className="grid grid-cols-1 lg:grid-cols-3 gap-6">
                    <div className="lg:col-span-2 space-y-6">
                        <div className="bg-gradient-to-br from-gray-50 to-white rounded-xl p-6 border border-gray-200">
                            <div className="grid grid-cols-2 gap-4">
                                <div className="p-3 bg-white rounded-lg border border-gray-100">
                                    <p className="text-gray-500 text-sm mb-1">License Plate</p>
                                    <p className="text-gray-900 font-bold text-xl">{car.plaka}</p>
                                </div>
                                <div className="p-3 bg-white rounded-lg border border-gray-100">
                                    <p className="text-gray-500 text-sm mb-1">Brand/Model</p>
                                    <p className="text-gray-900 font-semibold">{car.marka} {car.model}</p>
                                </div>
                                <div className="p-3 bg-white rounded-lg border border-gray-100">
                                    <p className="text-gray-500 text-sm mb-1">Category</p>
                                    <p className="text-gray-900 font-semibold">{car.kategori}</p>
                                </div>
                                <div className="p-3 bg-white rounded-lg border border-gray-100">
                                    <p className="text-gray-500 text-sm mb-1">Vignette</p>
                                    <p className={`font-semibold ${car.vignetteVar ? 'text-green-600' : 'text-red-600'}`}>
                                        {car.vignetteVar ? 'Yes' : 'No'}
                                    </p>
                                </div>
                            </div>
                        </div>

                        <div>
                            <div className="flex items-center justify-between mb-4">
                                <h4 className="text-lg font-bold text-gray-900 flex items-center gap-2">
                                    <AlertCircle className="text-orange-500" size={20} />
                                    Damage Records ({car.hasarKayitlari?.length || 0})
                                </h4>
                                <button onClick={() => setShowAddDamage(true)} 
                                        className="flex items-center gap-2 px-4 py-2 bg-orange-500 hover:bg-orange-600 text-white rounded-xl text-sm transition-colors shadow-lg shadow-orange-500/30">
                                    <Plus size={16} />Add Damage
                                </button>
                            </div>
                            <div className="space-y-3 max-h-[500px] overflow-y-auto pr-2">
                                {car.hasarKayitlari && car.hasarKayitlari.length > 0 ? (
                                    car.hasarKayitlari.map((damage, i) => (
                                        <div key={i} className="bg-gradient-to-r from-gray-50 to-white rounded-xl p-4 border border-gray-200 hover:border-orange-200 hover:shadow-md transition-all">
                                            <div className="flex items-start justify-between">
                                                <div className="flex-1">
                                                    <div className="flex items-center gap-2 mb-2">
                                                        <h5 className="text-gray-900 font-bold text-lg">{damage.resKodu}</h5>
                                                        <span className={`px-2 py-1 rounded-lg text-xs font-semibold ${
                                                            damage.durum === 'Done' ? 'bg-green-100 text-green-700' : 'bg-yellow-100 text-yellow-700'
                                                        }`}>
                                                            {damage.durum}
                                                        </span>
                                                    </div>
                                                    <div className="grid grid-cols-2 gap-3 text-sm mb-3">
                                                        <div className="flex items-center gap-2 text-gray-600">
                                                            <Car size={14} />
                                                            <span>{damage.km} km</span>
                                                        </div>
                                                        <div className="flex items-center gap-2 text-gray-600">
                                                            <Calendar size={14} />
                                                            <span>{formatDate(damage.tarih)}</span>
                                                        </div>
                                                        {damage.handoverTarihi && (
                                                            <div className="flex items-center gap-2 text-gray-600">
                                                                <Clock size={14} />
                                                                <span>Handover: {formatDate(damage.handoverTarihi)}</span>
                                                            </div>
                                                        )}
                                                        {damage.fotograflar?.length > 0 && (
                                                            <div className="flex items-center gap-2 text-blue-600">
                                                                <Camera size={14} />
                                                                <span>{damage.fotograflar.length} photos</span>
                                                            </div>
                                                        )}
                                                    </div>
                                                    <div className="flex gap-2">
                                                        <button onClick={() => handleToggleDamageStatus(i)}
                                                                className={`px-3 py-1.5 rounded-lg text-xs font-medium transition-colors ${
                                                                    damage.durum === 'Done' 
                                                                        ? 'bg-yellow-100 text-yellow-700 hover:bg-yellow-200' 
                                                                        : 'bg-green-100 text-green-700 hover:bg-green-200'
                                                                }`}>
                                                            {damage.durum === 'Done' ? 'Mark In Progress' : 'Mark Done'}
                                                        </button>
                                                        <button onClick={() => handleDeleteDamage(i)}
                                                                className="px-3 py-1.5 bg-red-100 text-red-700 hover:bg-red-200 rounded-lg text-xs font-medium transition-colors">
                                                            Delete
                                                        </button>
                                                    </div>
                                                </div>
                                                {damage.fotograflar?.length > 0 && (
                                                    <button onClick={() => { setSelectedPhotos(damage.fotograflar); setShowPhotoGallery(true); }}
                                                            className="ml-4 px-4 py-2 bg-blue-100 text-blue-600 rounded-xl hover:bg-blue-200 transition-colors flex items-center gap-2">
                                                        <Camera size={16} />
                                                        View
                                                    </button>
                                                )}
                                            </div>
                                        </div>
                                    ))
                                ) : (
                                    <div className="text-center py-12 bg-gray-50 rounded-xl border border-gray-200">
                                        <AlertCircle className="mx-auto text-gray-300 mb-3" size={48} />
                                        <p className="text-gray-400">No damage records</p>
                                    </div>
                                )}
                            </div>
                        </div>
                    </div>

                    <div className="space-y-4">
                        <div className="bg-gradient-to-br from-blue-50 to-blue-100 rounded-xl p-6 border border-blue-200 shadow-lg">
                            <div className="flex items-center gap-3 mb-4">
                                <Camera className="text-blue-600" size={24} />
                                <div>
                                    <p className="text-blue-900 text-sm font-medium">Total Photos</p>
                                    <p className="text-blue-900 text-3xl font-bold">{allPhotos.length}</p>
                                </div>
                            </div>
                            {allPhotos.length > 0 && (
                                <button onClick={() => { setSelectedPhotos(allPhotos); setShowPhotoGallery(true); }}
                                        className="w-full flex items-center justify-center gap-2 px-4 py-3 bg-blue-500 hover:bg-blue-600 text-white rounded-xl transition-colors shadow-lg shadow-blue-500/30">
                                    <Eye size={18} />View All Photos
                                </button>
                            )}
                        </div>

                        <button onClick={() => generateDamagePDF(car)}
                                className="w-full flex items-center justify-center gap-2 px-4 py-3 bg-gradient-to-r from-purple-500 to-purple-600 hover:from-purple-600 hover:to-purple-700 text-white rounded-xl transition-all shadow-lg shadow-purple-500/30">
                            <FileText size={18} />Generate PDF Report
                        </button>

                        <button onClick={() => setShowEditModal(true)}
                                className="w-full flex items-center justify-center gap-2 px-4 py-3 bg-gradient-to-r from-blue-500 to-blue-600 hover:from-blue-600 hover:to-blue-700 text-white rounded-xl transition-all shadow-lg shadow-blue-500/30">
                            <Edit size={18} />Edit Vehicle
                        </button>

                        <button onClick={() => setShowReturnModal(true)}
                                className="w-full flex items-center justify-center gap-2 px-4 py-3 bg-gradient-to-r from-green-500 to-green-600 hover:from-green-600 hover:to-green-700 text-white rounded-xl transition-all shadow-lg shadow-green-500/30">
                            <ArrowLeft size={18} />Process Return
                        </button>

                        <button onClick={handleDelete} 
                                className="w-full flex items-center justify-center gap-2 px-4 py-3 bg-gradient-to-r from-red-500 to-red-600 hover:from-red-600 hover:to-red-700 text-white rounded-xl transition-all shadow-lg shadow-red-500/30">
                            <Trash2 size={18} />Delete Vehicle
                        </button>
                    </div>
                </div>

                {showAddDamage && <AddDamageModal car={car} onClose={() => setShowAddDamage(false)} onSuccess={() => { setShowAddDamage(false); onSuccess(); }} addActivity={addActivity} />}
                {showPhotoGallery && <PhotoGalleryModal photos={selectedPhotos} onClose={() => setShowPhotoGallery(false)} />}
                {showReturnModal && <ReturnModal car={car} onClose={() => setShowReturnModal(false)} onSuccess={() => { setShowReturnModal(false); onSuccess(); }} addActivity={addActivity} />}
                {showEditModal && <EditCarModal car={editedCar} setCar={setEditedCar} onClose={() => setShowEditModal(false)} onSave={handleUpdate} />}
            </div>
        </div>
    );
}

function EditCarModal({ car, setCar, onClose, onSave }) {
    const categories = ['A','B','D','F','H','J','L','M','MB','MC','N','R','S','T','U','V','X','Y','Z'];
    
    return (
        <div className="fixed inset-0 bg-black/50 backdrop-blur-sm flex items-center justify-center p-4 z-[60]">
            <div className="bg-white rounded-2xl shadow-2xl border border-gray-200 p-6 w-full max-w-md">
                <div className="flex items-center justify-between mb-6">
                    <h3 className="text-xl font-bold text-gray-900">Edit Vehicle</h3>
                    <button onClick={onClose} className="text-gray-400 hover:text-gray-600"><X size={24} /></button>
                </div>
                <div className="space-y-4">
                    <div>
                        <label className="block text-sm font-medium text-gray-700 mb-2">License Plate</label>
                        <input type="text" value={car.plaka} onChange={(e) => setCar({...car, plaka: e.target.value})}
                               className="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 focus:outline-none focus:ring-2 focus:ring-blue-500" />
                    </div>
                    <div>
                        <label className="block text-sm font-medium text-gray-700 mb-2">Brand</label>
                        <input type="text" value={car.marka} onChange={(e) => setCar({...car, marka: e.target.value})}
                               className="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 focus:outline-none focus:ring-2 focus:ring-blue-500" />
                    </div>
                    <div>
                        <label className="block text-sm font-medium text-gray-700 mb-2">Model</label>
                        <input type="text" value={car.model} onChange={(e) => setCar({...car, model: e.target.value})}
                               className="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 focus:outline-none focus:ring-2 focus:ring-blue-500" />
                    </div>
                    <div>
                        <label className="block text-sm font-medium text-gray-700 mb-2">Category</label>
                        <select value={car.kategori} onChange={(e) => setCar({...car, kategori: e.target.value})}
                                className="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 focus:outline-none focus:ring-2 focus:ring-blue-500">
                            {categories.map(c => <option key={c} value={c}>{c}</option>)}
                        </select>
                    </div>
                    <div className="flex items-center gap-3 p-3 bg-gray-50 rounded-xl">
                        <input type="checkbox" id="edit-vig" checked={car.vignetteVar} onChange={(e) => setCar({...car, vignetteVar: e.target.checked})}
                               className="w-5 h-5 rounded border-gray-300 text-blue-600 focus:ring-blue-500" />
                        <label htmlFor="edit-vig" className="text-gray-700 font-medium">Has Vignette</label>
                    </div>
                    <div className="flex gap-3 pt-4">
                        <button onClick={onClose} className="flex-1 px-4 py-3 bg-gray-100 hover:bg-gray-200 text-gray-700 rounded-xl transition-colors font-medium">
                            Cancel
                        </button>
                        <button onClick={onSave} className="flex-1 px-4 py-3 bg-gradient-to-r from-blue-500 to-blue-600 hover:from-blue-600 hover:to-blue-700 text-white rounded-xl transition-colors shadow-lg shadow-blue-500/30 font-medium">
                            Save Changes
                        </button>
                    </div>
                </div>
            </div>
        </div>
    );
}

function AddDamageModal({ car, onClose, onSuccess, addActivity }) {
    const [resKodu, setResKodu] = useState('');
    const [km, setKm] = useState('');
    const [durum, setDurum] = useState('In Progress');
    const [handoverTarihi, setHandoverTarihi] = useState(new Date().toISOString().split('T')[0]);
    const [files, setFiles] = useState([]);
    const [loading, setLoading] = useState(false);
    const [uploadProgress, setUploadProgress] = useState(0);

    const handleSubmit = async () => {
        if (!resKodu || !km) {
            alert('Please fill RES Code and Kilometers');
            return;
        }
        setLoading(true);
        setUploadProgress(0);
        try {
            const photoURLs = [];
            for (let i = 0; i < files.length; i++) {
                const file = files[i];
                const storageRef = ref(storage, `hasar_fotograflari/${Date.now()}_${file.name}`);
                await uploadBytes(storageRef, file);
                const url = await getDownloadURL(storageRef);
                photoURLs.push(url);
                setUploadProgress(Math.round(((i + 1) / files.length) * 100));
            }
            const newDamage = { 
                resKodu, 
                km: parseInt(km), 
                tarih: Timestamp.now(),
                handoverTarihi: Timestamp.fromDate(new Date(handoverTarihi)),
                durum,
                fotograflar: photoURLs 
            };
            await updateDoc(doc(db, 'araclar', car.id), { 
                hasarKayitlari: [...(car.hasarKayitlari || []), newDamage] 
            });
            addActivity('Hasar Eklendi', `New damage ${resKodu} added to ${car.plaka}`);
            onSuccess();
        } catch (error) {
            console.error('Error:', error);
            alert('Failed to add damage');
        } finally {
            setLoading(false);
            setUploadProgress(0);
        }
    };

    return (
        <div className="fixed inset-0 bg-black/50 backdrop-blur-sm flex items-center justify-center p-4 z-[60]">
            <div className="bg-white rounded-2xl shadow-2xl border border-gray-200 p-6 w-full max-w-md max-h-[90vh] overflow-y-auto">
                <div className="flex items-center justify-between mb-6">
                    <h3 className="text-xl font-bold text-gray-900">Add Damage Record</h3>
                    <button onClick={onClose} className="text-gray-400 hover:text-gray-600 transition-colors"><X size={24} /></button>
                </div>
                <div className="space-y-4">
                    <div>
                        <label className="block text-sm font-medium text-gray-700 mb-2">RES Code *</label>
                        <input type="text" value={resKodu} onChange={(e) => setResKodu(e.target.value)} 
                               className="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 focus:outline-none focus:ring-2 focus:ring-blue-500" 
                               placeholder="RES-12345" />
                    </div>
                    <div>
                        <label className="block text-sm font-medium text-gray-700 mb-2">Kilometers *</label>
                        <input type="number" value={km} onChange={(e) => setKm(e.target.value)} 
                               className="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 focus:outline-none focus:ring-2 focus:ring-blue-500" 
                               placeholder="50000" />
                    </div>
                    <div>
                        <label className="block text-sm font-medium text-gray-700 mb-2">Handover Date</label>
                        <input type="date" value={handoverTarihi} onChange={(e) => setHandoverTarihi(e.target.value)} 
                               className="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 focus:outline-none focus:ring-2 focus:ring-blue-500" />
                    </div>
                    <div>
                        <label className="block text-sm font-medium text-gray-700 mb-2">Status</label>
                        <select value={durum} onChange={(e) => setDurum(e.target.value)}
                                className="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 focus:outline-none focus:ring-2 focus:ring-blue-500">
                            <option value="In Progress">In Progress</option>
                            <option value="Done">Done</option>
                        </select>
                    </div>
                    <div>
                        <label className="block text-sm font-medium text-gray-700 mb-2">Photos</label>
                        <div className="border-2 border-dashed border-gray-300 rounded-xl p-6 text-center hover:border-blue-400 transition-colors cursor-pointer">
                            <input type="file" accept="image/*" multiple onChange={(e) => setFiles(Array.from(e.target.files))} 
                                   className="hidden" id="file-input" />
                            <label htmlFor="file-input" className="cursor-pointer">
                                <Upload className="mx-auto text-gray-400 mb-2" size={32} />
                                <p className="text-gray-600 text-sm">Click to upload photos</p>
                                <p className="text-gray-400 text-xs mt-1">PNG, JPG up to 10MB</p>
                            </label>
                        </div>
                        {files.length > 0 && (
                            <div className="mt-3 p-3 bg-blue-50 border border-blue-200 rounded-lg">
                                <p className="text-blue-900 text-sm font-medium flex items-center gap-2">
                                    <ImageIcon size={16} />
                                    {files.length} file(s) selected
                                </p>
                            </div>
                        )}
                        {uploadProgress > 0 && uploadProgress < 100 && (
                            <div className="mt-3">
                                <div className="flex justify-between text-sm text-gray-600 mb-1">
                                    <span>Uploading...</span>
                                    <span>{uploadProgress}%</span>
                                </div>
                                <div className="w-full bg-gray-200 rounded-full h-2">
                                    <div className="bg-blue-500 h-2 rounded-full transition-all" style={{width: `${uploadProgress}%`}}></div>
                                </div>
                            </div>
                        )}
                    </div>
                    <div className="flex gap-3 pt-4">
                        <button onClick={onClose} disabled={loading} 
                                className="flex-1 px-4 py-3 bg-gray-100 hover:bg-gray-200 text-gray-700 rounded-xl transition-colors font-medium disabled:opacity-50">
                            Cancel
                        </button>
                        <button onClick={handleSubmit} disabled={loading} 
                                className="flex-1 px-4 py-3 bg-gradient-to-r from-orange-500 to-orange-600 hover:from-orange-600 hover:to-orange-700 text-white rounded-xl transition-colors shadow-lg shadow-orange-500/30 font-medium disabled:opacity-50">
                            {loading ? 'Adding...' : 'Add Damage'}
                        </button>
                    </div>
                </div>
            </div>
        </div>
    );
}

function PhotoGalleryModal({ photos, onClose }) {
    const [currentIndex, setCurrentIndex] = useState(0);

    return (
        <div className="fixed inset-0 bg-black/95 backdrop-blur-md flex items-center justify-center p-4 z-[70]">
            <div className="w-full max-w-6xl">
                <div className="flex items-center justify-between mb-6">
                    <h3 className="text-2xl font-bold text-white flex items-center gap-3">
                        <Camera className="text-blue-400" size={28} />
                        Photo Gallery ({currentIndex + 1}/{photos.length})
                    </h3>
                    <button onClick={onClose} className="text-white hover:text-gray-300 transition-colors">
                        <X size={32} />
                    </button>
                </div>
                <div className="bg-white rounded-2xl p-4 shadow-2xl">
                    <img src={photos[currentIndex]} alt="Damage" className="w-full h-auto max-h-[70vh] object-contain rounded-xl" />
                </div>
                <div className="flex items-center justify-center gap-4 mt-6">
                    <button onClick={() => setCurrentIndex(Math.max(0, currentIndex - 1))} disabled={currentIndex === 0}
                            className="px-6 py-3 bg-white hover:bg-gray-100 text-gray-900 rounded-xl disabled:opacity-30 disabled:cursor-not-allowed transition-all shadow-lg font-medium flex items-center gap-2">
                        <ChevronRight size={20} className="rotate-180" />
                        Previous
                    </button>
                    <div className="text-white font-medium px-4 py-2 bg-white/10 rounded-lg">
                        {currentIndex + 1} / {photos.length}
                    </div>
                    <button onClick={() => setCurrentIndex(Math.min(photos.length - 1, currentIndex + 1))} disabled={currentIndex === photos.length - 1}
                            className="px-6 py-3 bg-white hover:bg-gray-100 text-gray-900 rounded-xl disabled:opacity-30 disabled:cursor-not-allowed transition-all shadow-lg font-medium flex items-center gap-2">
                        Next
                        <ChevronRight size={20} />
                    </button>
                </div>
            </div>
        </div>
    );
}

function ReturnModal({ car, onClose, onSuccess, addActivity }) {
    const [notlar, setNotlar] = useState('');
    const [loading, setLoading] = useState(false);

    const handleSubmit = async () => {
        setLoading(true);
        try {
            await addDoc(collection(db, 'iadeIslemleri'), {
                aracId: car.id,
                aracPlaka: car.plaka,
                iadeTarihi: Timestamp.now(),
                notlar,
                hasarSayisi: car.hasarKayitlari?.length || 0,
                fotografSayisi: car.hasarKayitlari?.reduce((acc, h) => acc + (h.fotograflar?.length || 0), 0) || 0
            });
            addActivity('İade İşlemi', `Return processed for ${car.plaka}`);
            onSuccess();
        } catch (error) {
            alert('Failed to process return');
        } finally {
            setLoading(false);
        }
    };

    return (
        <div className="fixed inset-0 bg-black/50 backdrop-blur-sm flex items-center justify-center p-4 z-[60]">
            <div className="bg-white rounded-2xl shadow-2xl border border-gray-200 p-6 w-full max-w-md">
                <div className="flex items-center justify-between mb-6">
                    <h3 className="text-xl font-bold text-gray-900 flex items-center gap-2">
                        <ArrowLeft className="text-green-500" size={24} />
                        Process Return
                    </h3>
                    <button onClick={onClose} className="text-gray-400 hover:text-gray-600 transition-colors"><X size={24} /></button>
                </div>
                <div className="space-y-4">
                    <div className="bg-gradient-to-r from-gray-50 to-white rounded-xl p-4 border border-gray-200">
                        <p className="text-gray-500 text-sm mb-1">Vehicle</p>
                        <p className="text-gray-900 font-bold text-xl">{car.plaka}</p>
                        <p className="text-gray-600">{car.marka} {car.model}</p>
                        <div className="grid grid-cols-2 gap-3 mt-3 pt-3 border-t border-gray-200">
                            <div>
                                <p className="text-gray-500 text-xs">Damages</p>
                                <p className="text-gray-900 font-bold">{car.hasarKayitlari?.length || 0}</p>
                            </div>
                            <div>
                                <p className="text-gray-500 text-xs">Photos</p>
                                <p className="text-gray-900 font-bold">
                                    {car.hasarKayitlari?.reduce((acc, h) => acc + (h.fotograflar?.length || 0), 0) || 0}
                                </p>
                            </div>
                        </div>
                    </div>
                    <div>
                        <label className="block text-sm font-medium text-gray-700 mb-2">Notes</label>
                        <textarea value={notlar} onChange={(e) => setNotlar(e.target.value)} rows="4" 
                                  className="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 focus:outline-none focus:ring-2 focus:ring-green-500 resize-none" 
                                  placeholder="Add any notes about the return..." />
                    </div>
                    <div className="flex gap-3 pt-4">
                        <button onClick={onClose} disabled={loading} 
                                className="flex-1 px-4 py-3 bg-gray-100 hover:bg-gray-200 text-gray-700 rounded-xl transition-colors font-medium disabled:opacity-50">
                            Cancel
                        </button>
                        <button onClick={handleSubmit} disabled={loading} 
                                className="flex-1 px-4 py-3 bg-gradient-to-r from-green-500 to-green-600 hover:from-green-600 hover:to-green-700 text-white rounded-xl transition-colors shadow-lg shadow-green-500/30 font-medium disabled:opacity-50">
                            {loading ? 'Processing...' : 'Process Return'}
                        </button>
                    </div>
                </div>
            </div>
        </div>
    );
}

// RETURNS VIEW
function ReturnsView({ returns, cars, onRefresh, addActivity }) {
    const [searchQuery, setSearchQuery] = useState('');
    const [selectedReturn, setSelectedReturn] = useState(null);
    const [showDetailModal, setShowDetailModal] = useState(false);

    const filteredReturns = returns.filter(ret => {
        const query = searchQuery.toLowerCase();
        return ret.aracPlaka?.toLowerCase().includes(query) || ret.notlar?.toLowerCase().includes(query);
    });

    const handleDeleteReturn = async (returnId) => {
        if (!window.confirm('Are you sure you want to delete this return record?')) return;
        try {
            await deleteDoc(doc(db, 'iadeIslemleri', returnId));
            addActivity('İade Silindi', 'Return record deleted');
            onRefresh();
        } catch (error) {
            alert('Failed to delete return');
        }
    };

    return (
        <div className="space-y-6">
            <div className="flex items-center justify-between gap-4 flex-wrap">
                <div>
                    <h2 className="text-4xl font-bold text-gray-900 flex items-center gap-3">
                        <ArrowLeft className="text-green-500" size={36} />
                        Return Records
                    </h2>
                    <p className="text-gray-500 mt-1">{filteredReturns.length} of {returns.length} returns</p>
                </div>
            </div>

            <div className="bg-white rounded-2xl shadow-lg border border-gray-200 p-4">
                <div className="relative">
                    <Search className="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400" size={20} />
                    <input
                        type="text"
                        value={searchQuery}
                        onChange={(e) => setSearchQuery(e.target.value)}
                        placeholder="Search by plate or notes..."
                        className="w-full pl-10 pr-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 focus:outline-none focus:ring-2 focus:ring-green-500"
                    />
                </div>
            </div>

            {filteredReturns.length > 0 ? (
                <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                    {filteredReturns.map((ret) => {
                        const car = cars.find(c => c.id === ret.aracId);
                        return (
                            <div key={ret.id} className="bg-white rounded-2xl border border-gray-200 p-6 shadow-lg shadow-gray-200/50 hover:shadow-xl hover:border-green-300 transition-all group">
                                <div className="flex items-start justify-between mb-4">
                                    <div className="flex items-center gap-3">
                                        <div className="w-14 h-14 bg-gradient-to-br from-green-100 to-green-50 rounded-xl flex items-center justify-center group-hover:scale-110 transition-transform">
                                            <ArrowLeft className="text-green-600" size={28} />
                                        </div>
                                        <div>
                                            <h3 className="text-lg font-bold text-gray-900">{ret.aracPlaka || car?.plaka}</h3>
                                            <p className="text-gray-500 text-sm">{car?.marka} {car?.model}</p>
                                        </div>
                                    </div>
                                </div>
                                <div className="space-y-3 text-sm">
                                    <div className="flex justify-between items-center p-3 bg-gray-50 rounded-lg">
                                        <span className="text-gray-600">Return Date:</span>
                                        <span className="text-gray-900 font-medium">{formatDate(ret.iadeTarihi)}</span>
                                    </div>
                                    <div className="flex justify-between items-center p-3 bg-gray-50 rounded-lg">
                                        <span className="text-gray-600">Damages:</span>
                                        <span className="text-gray-900 font-bold">{ret.hasarSayisi || 0}</span>
                                    </div>
                                    <div className="flex justify-between items-center p-3 bg-gray-50 rounded-lg">
                                        <span className="text-gray-600">Photos:</span>
                                        <span className="text-gray-900 font-bold">{ret.fotografSayisi || 0}</span>
                                    </div>
                                    {ret.notlar && (
                                        <div className="mt-3 p-3 bg-green-50 rounded-lg border border-green-200">
                                            <p className="text-green-800 text-xs font-medium mb-1">Notes:</p>
                                            <p className="text-gray-600 text-xs">{ret.notlar}</p>
                                        </div>
                                    )}
                                </div>
                                <div className="mt-4 pt-4 border-t border-gray-200 flex gap-2">
                                    <button onClick={() => { setSelectedReturn(ret); setShowDetailModal(true); }}
                                            className="flex-1 px-3 py-2 bg-blue-100 text-blue-700 hover:bg-blue-200 rounded-lg text-sm font-medium transition-colors flex items-center justify-center gap-2">
                                        <Eye size={14} />View
                                    </button>
                                    <button onClick={() => handleDeleteReturn(ret.id)}
                                            className="flex-1 px-3 py-2 bg-red-100 text-red-700 hover:bg-red-200 rounded-lg text-sm font-medium transition-colors flex items-center justify-center gap-2">
                                        <Trash2 size={14} />Delete
                                    </button>
                                </div>
                            </div>
                        );
                    })}
                </div>
            ) : (
                <div className="text-center py-20 bg-white rounded-2xl border border-gray-200">
                    <ArrowLeft className="mx-auto text-gray-300 mb-4" size={64} />
                    <h3 className="text-xl font-semibold text-gray-400 mb-2">No Return Records</h3>
                    <p className="text-gray-500">Return records will appear here</p>
                </div>
            )}

            {showDetailModal && selectedReturn && <ReturnDetailModal return={selectedReturn} cars={cars} onClose={() => setShowDetailModal(false)} />}
        </div>
    );
}

function ReturnDetailModal({ return: ret, cars, onClose }) {
    const car = cars.find(c => c.id === ret.aracId);
    
    const generateReturnPDF = () => {
        const content = `
VEHICLE RETURN REPORT
====================
Generated: ${new Date().toLocaleString()}

Vehicle Information:
- Plate: ${ret.aracPlaka || 'N/A'}
- Brand/Model: ${car ? `${car.marka} ${car.model}` : 'N/A'}
- Category: ${car?.kategori || 'N/A'}

Return Details:
- Return Date: ${formatDateTime(ret.iadeTarihi)}
- Number of Damages: ${ret.hasarSayisi || 0}
- Number of Photos: ${ret.fotografSayisi || 0}

${ret.notlar ? `Notes:\n${ret.notlar}` : 'No notes'}

---
Green Motion AG - Zurich, Switzerland
`;
        const blob = new Blob([content], { type: 'text/plain' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = `Return_${ret.aracPlaka}_${Date.now()}.txt`;
        a.click();
    };

    return (
        <div className="fixed inset-0 bg-black/30 backdrop-blur-sm flex items-center justify-center p-4 z-50">
            <div className="bg-white rounded-2xl shadow-2xl border border-gray-200 p-6 w-full max-w-2xl">
                <div className="flex items-center justify-between mb-6">
                    <h3 className="text-2xl font-bold text-gray-900">Return Details</h3>
                    <button onClick={onClose} className="text-gray-400 hover:text-gray-600"><X size={24} /></button>
                </div>
                <div className="space-y-4">
                    <div className="grid grid-cols-2 gap-4">
                        <div className="p-4 bg-gray-50 rounded-xl border border-gray-200">
                            <p className="text-gray-500 text-sm mb-1">Plate</p>
                            <p className="text-gray-900 font-bold text-lg">{ret.aracPlaka}</p>
                        </div>
                        <div className="p-4 bg-gray-50 rounded-xl border border-gray-200">
                            <p className="text-gray-500 text-sm mb-1">Vehicle</p>
                            <p className="text-gray-900 font-semibold">{car ? `${car.marka} ${car.model}` : 'N/A'}</p>
                        </div>
                        <div className="p-4 bg-gray-50 rounded-xl border border-gray-200">
                            <p className="text-gray-500 text-sm mb-1">Return Date</p>
                            <p className="text-gray-900 font-semibold">{formatDateTime(ret.iadeTarihi)}</p>
                        </div>
                        <div className="p-4 bg-gray-50 rounded-xl border border-gray-200">
                            <p className="text-gray-500 text-sm mb-1">Damages</p>
                            <p className="text-orange-600 font-bold text-xl">{ret.hasarSayisi || 0}</p>
                        </div>
                    </div>
                    {ret.notlar && (
                        <div className="p-4 bg-green-50 rounded-xl border border-green-200">
                            <p className="text-green-900 font-semibold mb-2">Notes:</p>
                            <p className="text-gray-700">{ret.notlar}</p>
                        </div>
                    )}
                    <div className="flex gap-3 pt-4">
                        <button onClick={onClose} className="flex-1 px-4 py-3 bg-gray-100 hover:bg-gray-200 text-gray-700 rounded-xl transition-colors font-medium">
                            Close
                        </button>
                        <button onClick={generateReturnPDF} className="flex-1 px-4 py-3 bg-gradient-to-r from-blue-500 to-blue-600 hover:from-blue-600 hover:to-blue-700 text-white rounded-xl transition-colors shadow-lg shadow-blue-500/30 font-medium flex items-center justify-center gap-2">
                            <Download size={18} />Generate Report
                        </button>
                    </div>
                </div>
            </div>
        </div>
    );
}

// Dosya çok uzun, Part 3'te devam edeceğim...

// SERVICE VIEW
function ServiceView({ services, cars, serviceFirms, onRefresh, addActivity }) {
    const [showAddModal, setShowAddModal] = useState(false);
    const [selectedService, setSelectedService] = useState(null);
    const [showDetailModal, setShowDetailModal] = useState(false);
    const [searchQuery, setSearchQuery] = useState('');

    const filteredServices = services.filter(service => {
        const query = searchQuery.toLowerCase();
        const car = cars.find(c => c.id === service.aracId);
        return service.servisTuru?.toLowerCase().includes(query) ||
               service.aciklama?.toLowerCase().includes(query) ||
               car?.plaka?.toLowerCase().includes(query);
    });

    const handleDeleteService = async (serviceId) => {
        if (!window.confirm('Are you sure?')) return;
        try {
            await deleteDoc(doc(db, 'servisler', serviceId));
            addActivity('Servis Silindi', 'Service record deleted');
            onRefresh();
        } catch (error) {
            alert('Failed to delete service');
        }
    };

    return (
        <div className="space-y-6">
            <div className="flex items-center justify-between gap-4 flex-wrap">
                <div>
                    <h2 className="text-4xl font-bold text-gray-900 flex items-center gap-3">
                        <Package className="text-purple-500" size={36} />
                        Service Records
                    </h2>
                    <p className="text-gray-500 mt-1">{filteredServices.length} of {services.length} services</p>
                </div>
                <button onClick={() => setShowAddModal(true)}
                        className="flex items-center gap-2 px-6 py-3 bg-gradient-to-r from-purple-500 to-purple-600 hover:from-purple-600 hover:to-purple-700 text-white rounded-xl transition-all shadow-lg shadow-purple-500/30 font-medium">
                    <Plus size={20} />Add Service
                </button>
            </div>

            <div className="bg-white rounded-2xl shadow-lg border border-gray-200 p-4">
                <div className="relative">
                    <Search className="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400" size={20} />
                    <input
                        type="text"
                        value={searchQuery}
                        onChange={(e) => setSearchQuery(e.target.value)}
                        placeholder="Search by type, description, or plate..."
                        className="w-full pl-10 pr-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 focus:outline-none focus:ring-2 focus:ring-purple-500"
                    />
                </div>
            </div>

            {filteredServices.length > 0 ? (
                <div className="space-y-4">
                    {filteredServices.map((service) => {
                        const car = cars.find(c => c.id === service.aracId);
                        const firm = serviceFirms.find(f => f.id === service.servisFirmaId);
                        return (
                            <div key={service.id} className="bg-white rounded-2xl border border-gray-200 p-6 shadow-lg shadow-gray-200/50 hover:shadow-xl hover:border-purple-300 transition-all">
                                <div className="flex items-start justify-between">
                                    <div className="flex items-start gap-4 flex-1">
                                        <div className="w-14 h-14 bg-gradient-to-br from-purple-100 to-purple-50 rounded-xl flex items-center justify-center">
                                            <Package className="text-purple-600" size={28} />
                                        </div>
                                        <div className="flex-1">
                                            <div className="flex items-center gap-3 mb-2">
                                                <h3 className="text-lg font-bold text-gray-900">{service.servisTuru || 'Service'}</h3>
                                                {car && (
                                                    <span className="px-3 py-1 bg-blue-100 text-blue-700 text-sm font-semibold rounded-lg">
                                                        {car.plaka}
                                                    </span>
                                                )}
                                            </div>
                                            <p className="text-gray-600 mb-3">{service.aciklama}</p>
                                            <div className="flex items-center gap-4 text-sm text-gray-500">
                                                {firm && (
                                                    <span className="flex items-center gap-1">
                                                        <Building2 size={14} />
                                                        {firm.firmaAdi}
                                                    </span>
                                                )}
                                                <span className="flex items-center gap-1">
                                                    <Calendar size={14} />
                                                    {formatDateTime(service.tarih)}
                                                </span>
                                                {service.tutar && (
                                                    <span className="flex items-center gap-1 text-green-600 font-semibold">
                                                        <DollarSign size={14} />
                                                        {formatCurrency(service.tutar)}
                                                    </span>
                                                )}
                                            </div>
                                        </div>
                                    </div>
                                    <div className="flex gap-2">
                                        <button onClick={() => { setSelectedService(service); setShowDetailModal(true); }}
                                                className="px-4 py-2 bg-blue-100 text-blue-700 hover:bg-blue-200 rounded-lg transition-colors flex items-center gap-2">
                                            <Eye size={16} />View
                                        </button>
                                        <button onClick={() => handleDeleteService(service.id)}
                                                className="px-4 py-2 bg-red-100 text-red-700 hover:bg-red-200 rounded-lg transition-colors">
                                            <Trash2 size={16} />
                                        </button>
                                    </div>
                                </div>
                            </div>
                        );
                    })}
                </div>
            ) : (
                <div className="text-center py-20 bg-white rounded-2xl border border-gray-200">
                    <Package className="mx-auto text-gray-300 mb-4" size={64} />
                    <h3 className="text-xl font-semibold text-gray-400 mb-2">No Service Records</h3>
                    <p className="text-gray-500">Service records will appear here</p>
                </div>
            )}

            {showAddModal && <AddServiceModal cars={cars} serviceFirms={serviceFirms} onClose={() => setShowAddModal(false)} onSuccess={() => { setShowAddModal(false); onRefresh(); }} addActivity={addActivity} />}
            {showDetailModal && selectedService && <ServiceDetailModal service={selectedService} car={cars.find(c => c.id === selectedService.aracId)} firm={serviceFirms.find(f => f.id === selectedService.servisFirmaId)} onClose={() => setShowDetailModal(false)} />}
        </div>
    );
}

function AddServiceModal({ cars, serviceFirms, onClose, onSuccess, addActivity }) {
    const [formData, setFormData] = useState({
        aracId: '',
        servisFirmaId: '',
        servisTuru: '',
        aciklama: '',
        tutar: '',
        kilometre: ''
    });
    const [loading, setLoading] = useState(false);

    const handleSubmit = async () => {
        if (!formData.aracId || !formData.servisTuru) {
            alert('Please select vehicle and enter service type');
            return;
        }
        setLoading(true);
        try {
            await addDoc(collection(db, 'servisKayitlari'), {
                ...formData,
                tutar: formData.tutar ? parseFloat(formData.tutar) : 0,
                kilometre: formData.kilometre ? parseInt(formData.kilometre) : 0,
                tarih: Timestamp.now()
            });
            addActivity('Servis Eklendi', `New service record added`);
            onSuccess();
        } catch (error) {
            console.error('Error:', error);
            alert('Failed to add service');
        } finally {
            setLoading(false);
        }
    };

    return (
        <div className="fixed inset-0 bg-black/30 backdrop-blur-sm flex items-center justify-center p-4 z-50">
            <div className="bg-white rounded-2xl shadow-2xl border border-gray-200 p-6 w-full max-w-md max-h-[90vh] overflow-y-auto">
                <div className="flex items-center justify-between mb-6">
                    <h3 className="text-2xl font-bold text-gray-900">Add Service Record</h3>
                    <button onClick={onClose} className="text-gray-400 hover:text-gray-600"><X size={24} /></button>
                </div>
                <div className="space-y-4">
                    <div>
                        <label className="block text-sm font-medium text-gray-700 mb-2">Vehicle *</label>
                        <select value={formData.aracId} onChange={(e) => setFormData({...formData, aracId: e.target.value})}
                                className="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 focus:outline-none focus:ring-2 focus:ring-purple-500">
                            <option value="">Select Vehicle</option>
                            {cars.map(car => (
                                <option key={car.id} value={car.id}>{car.plaka} - {car.marka} {car.model}</option>
                            ))}
                        </select>
                    </div>
                    <div>
                        <label className="block text-sm font-medium text-gray-700 mb-2">Service Firm</label>
                        <select value={formData.servisFirmaId} onChange={(e) => setFormData({...formData, servisFirmaId: e.target.value})}
                                className="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 focus:outline-none focus:ring-2 focus:ring-purple-500">
                            <option value="">Select Firm (Optional)</option>
                            {serviceFirms.map(firm => (
                                <option key={firm.id} value={firm.id}>{firm.firmaAdi}</option>
                            ))}
                        </select>
                    </div>
                    <div>
                        <label className="block text-sm font-medium text-gray-700 mb-2">Service Type *</label>
                        <input type="text" value={formData.servisTuru} onChange={(e) => setFormData({...formData, servisTuru: e.target.value})}
                               className="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 focus:outline-none focus:ring-2 focus:ring-purple-500"
                               placeholder="Oil Change, Tire Replacement, etc." />
                    </div>
                    <div>
                        <label className="block text-sm font-medium text-gray-700 mb-2">Description</label>
                        <textarea value={formData.aciklama} onChange={(e) => setFormData({...formData, aciklama: e.target.value})} rows="3"
                                  className="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 focus:outline-none focus:ring-2 focus:ring-purple-500 resize-none"
                                  placeholder="Service details..." />
                    </div>
                    <div className="grid grid-cols-2 gap-4">
                        <div>
                            <label className="block text-sm font-medium text-gray-700 mb-2">Amount (CHF)</label>
                            <input type="number" step="0.01" value={formData.tutar} onChange={(e) => setFormData({...formData, tutar: e.target.value})}
                                   className="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 focus:outline-none focus:ring-2 focus:ring-purple-500"
                                   placeholder="0.00" />
                        </div>
                        <div>
                            <label className="block text-sm font-medium text-gray-700 mb-2">Kilometers</label>
                            <input type="number" value={formData.kilometre} onChange={(e) => setFormData({...formData, kilometre: e.target.value})}
                                   className="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 focus:outline-none focus:ring-2 focus:ring-purple-500"
                                   placeholder="50000" />
                        </div>
                    </div>
                    <div className="flex gap-3 pt-4">
                        <button onClick={onClose} disabled={loading}
                                className="flex-1 px-4 py-3 bg-gray-100 hover:bg-gray-200 text-gray-700 rounded-xl transition-colors font-medium disabled:opacity-50">
                            Cancel
                        </button>
                        <button onClick={handleSubmit} disabled={loading}
                                className="flex-1 px-4 py-3 bg-gradient-to-r from-purple-500 to-purple-600 hover:from-purple-600 hover:to-purple-700 text-white rounded-xl transition-colors shadow-lg shadow-purple-500/30 font-medium disabled:opacity-50">
                            {loading ? 'Adding...' : 'Add Service'}
                        </button>
                    </div>
                </div>
            </div>
        </div>
    );
}

function ServiceDetailModal({ service, car, firm, onClose }) {
    return (
        <div className="fixed inset-0 bg-black/30 backdrop-blur-sm flex items-center justify-center p-4 z-50">
            <div className="bg-white rounded-2xl shadow-2xl border border-gray-200 p-6 w-full max-w-2xl">
                <div className="flex items-center justify-between mb-6">
                    <h3 className="text-2xl font-bold text-gray-900">Service Details</h3>
                    <button onClick={onClose} className="text-gray-400 hover:text-gray-600"><X size={24} /></button>
                </div>
                <div className="space-y-4">
                    <div className="grid grid-cols-2 gap-4">
                        <div className="p-4 bg-gray-50 rounded-xl border border-gray-200">
                            <p className="text-gray-500 text-sm mb-1">Service Type</p>
                            <p className="text-gray-900 font-bold text-lg">{service.servisTuru}</p>
                        </div>
                        <div className="p-4 bg-gray-50 rounded-xl border border-gray-200">
                            <p className="text-gray-500 text-sm mb-1">Vehicle</p>
                            <p className="text-gray-900 font-semibold">{car ? `${car.plaka} - ${car.marka} ${car.model}` : 'N/A'}</p>
                        </div>
                        {firm && (
                            <div className="p-4 bg-gray-50 rounded-xl border border-gray-200">
                                <p className="text-gray-500 text-sm mb-1">Service Firm</p>
                                <p className="text-gray-900 font-semibold">{firm.firmaAdi}</p>
                            </div>
                        )}
                        <div className="p-4 bg-gray-50 rounded-xl border border-gray-200">
                            <p className="text-gray-500 text-sm mb-1">Date</p>
                            <p className="text-gray-900 font-semibold">{formatDateTime(service.tarih)}</p>
                        </div>
                        {service.tutar > 0 && (
                            <div className="p-4 bg-green-50 rounded-xl border border-green-200">
                                <p className="text-green-700 text-sm mb-1">Amount</p>
                                <p className="text-green-900 font-bold text-xl">{formatCurrency(service.tutar)}</p>
                            </div>
                        )}
                        {service.kilometre > 0 && (
                            <div className="p-4 bg-gray-50 rounded-xl border border-gray-200">
                                <p className="text-gray-500 text-sm mb-1">Kilometers</p>
                                <p className="text-gray-900 font-bold text-lg">{service.kilometre.toLocaleString()} km</p>
                            </div>
                        )}
                    </div>
                    {service.aciklama && (
                        <div className="p-4 bg-purple-50 rounded-xl border border-purple-200">
                            <p className="text-purple-900 font-semibold mb-2">Description:</p>
                            <p className="text-gray-700">{service.aciklama}</p>
                        </div>
                    )}
                    <button onClick={onClose} className="w-full px-4 py-3 bg-gray-100 hover:bg-gray-200 text-gray-700 rounded-xl transition-colors font-medium">
                        Close
                    </button>
                </div>
            </div>
        </div>
    );
}

// SERVICE FIRMS VIEW
function ServiceFirmsView({ firms, onRefresh, addActivity }) {
    const [showAddModal, setShowAddModal] = useState(false);
    const [selectedFirm, setSelectedFirm] = useState(null);
    const [showDetailModal, setShowDetailModal] = useState(false);
    const [searchQuery, setSearchQuery] = useState('');

    const filteredFirms = firms.filter(firm => {
        const query = searchQuery.toLowerCase();
        return firm.firmaAdi?.toLowerCase().includes(query) ||
               firm.telefon?.toLowerCase().includes(query) ||
               firm.email?.toLowerCase().includes(query);
    });

    const handleDeleteFirm = async (firmId) => {
        if (!window.confirm('Are you sure?')) return;
        try {
            await deleteDoc(doc(db, 'servisFirmalari', firmId));
            addActivity('Servis Firması Silindi', 'Service firm deleted');
            onRefresh();
        } catch (error) {
            alert('Failed to delete firm');
        }
    };

    return (
        <div className="space-y-6">
            <div className="flex items-center justify-between gap-4 flex-wrap">
                <div>
                    <h2 className="text-4xl font-bold text-gray-900 flex items-center gap-3">
                        <Building2 className="text-blue-500" size={36} />
                        Service Firms
                    </h2>
                    <p className="text-gray-500 mt-1">{filteredFirms.length} of {firms.length} firms</p>
                </div>
                <button onClick={() => setShowAddModal(true)}
                        className="flex items-center gap-2 px-6 py-3 bg-gradient-to-r from-blue-500 to-blue-600 hover:from-blue-600 hover:to-blue-700 text-white rounded-xl transition-all shadow-lg shadow-blue-500/30 font-medium">
                    <Plus size={20} />Add Firm
                </button>
            </div>

            <div className="bg-white rounded-2xl shadow-lg border border-gray-200 p-4">
                <div className="relative">
                    <Search className="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400" size={20} />
                    <input
                        type="text"
                        value={searchQuery}
                        onChange={(e) => setSearchQuery(e.target.value)}
                        placeholder="Search firms..."
                        className="w-full pl-10 pr-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 focus:outline-none focus:ring-2 focus:ring-blue-500"
                    />
                </div>
            </div>

            {filteredFirms.length > 0 ? (
                <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                    {filteredFirms.map((firm) => (
                        <div key={firm.id} className="bg-white rounded-2xl border border-gray-200 p-6 shadow-lg shadow-gray-200/50 hover:shadow-xl hover:border-blue-300 transition-all group">
                            <div className="flex items-start gap-4 mb-4">
                                <div className="w-14 h-14 bg-gradient-to-br from-blue-100 to-blue-50 rounded-xl flex items-center justify-center group-hover:scale-110 transition-transform">
                                    <Building2 className="text-blue-600" size={28} />
                                </div>
                                <div className="flex-1">
                                    <h3 className="text-lg font-bold text-gray-900">{firm.firmaAdi}</h3>
                                    <p className="text-gray-500 text-sm">{firm.adres || 'No address'}</p>
                                </div>
                            </div>
                            <div className="space-y-2 text-sm mb-4">
                                {firm.telefon && (
                                    <div className="flex items-center gap-2 text-gray-600">
                                        <Phone size={14} />
                                        <span>{firm.telefon}</span>
                                    </div>
                                )}
                                {firm.email && (
                                    <div className="flex items-center gap-2 text-gray-600">
                                        <Mail size={14} />
                                        <span className="truncate">{firm.email}</span>
                                    </div>
                                )}
                                {firm.website && (
                                    <div className="flex items-center gap-2 text-blue-600">
                                        <Globe size={14} />
                                        <a href={firm.website} target="_blank" rel="noopener noreferrer" className="truncate hover:underline">
                                            {firm.website}
                                        </a>
                                    </div>
                                )}
                            </div>
                            <div className="flex gap-2 pt-4 border-t border-gray-200">
                                <button onClick={() => { setSelectedFirm(firm); setShowDetailModal(true); }}
                                        className="flex-1 px-3 py-2 bg-blue-100 text-blue-700 hover:bg-blue-200 rounded-lg font-medium transition-colors flex items-center justify-center gap-2">
                                    <Eye size={14} />View
                                </button>
                                <button onClick={() => handleDeleteFirm(firm.id)}
                                        className="flex-1 px-3 py-2 bg-red-100 text-red-700 hover:bg-red-200 rounded-lg font-medium transition-colors flex items-center justify-center gap-2">
                                    <Trash2 size={14} />Delete
                                </button>
                            </div>
                        </div>
                    ))}
                </div>
            ) : (
                <div className="text-center py-20 bg-white rounded-2xl border border-gray-200">
                    <Building2 className="mx-auto text-gray-300 mb-4" size={64} />
                    <h3 className="text-xl font-semibold text-gray-400 mb-2">No Service Firms</h3>
                    <p className="text-gray-500">Add your first service firm</p>
                </div>
            )}

            {showAddModal && <AddServiceFirmModal onClose={() => setShowAddModal(false)} onSuccess={() => { setShowAddModal(false); onRefresh(); }} addActivity={addActivity} />}
            {showDetailModal && selectedFirm && <ServiceFirmDetailModal firm={selectedFirm} onClose={() => setShowDetailModal(false)} onUpdate={onRefresh} addActivity={addActivity} />}
        </div>
    );
}

function AddServiceFirmModal({ onClose, onSuccess, addActivity }) {
    const [formData, setFormData] = useState({
        firmaAdi: '',
        telefon: '',
        email: '',
        adres: '',
        website: '',
        notlar: ''
    });
    const [loading, setLoading] = useState(false);

    const handleSubmit = async () => {
        if (!formData.firmaAdi) {
            alert('Please enter firm name');
            return;
        }
        setLoading(true);
        try {
            await addDoc(collection(db, 'servisFirmalari'), {
                ...formData,
                kayitTarihi: Timestamp.now()
            });
            addActivity('Servis Firması Eklendi', `${formData.firmaAdi} added`);
            onSuccess();
        } catch (error) {
            console.error('Error:', error);
            alert('Failed to add firm');
        } finally {
            setLoading(false);
        }
    };

    return (
        <div className="fixed inset-0 bg-black/30 backdrop-blur-sm flex items-center justify-center p-4 z-50">
            <div className="bg-white rounded-2xl shadow-2xl border border-gray-200 p-6 w-full max-w-md max-h-[90vh] overflow-y-auto">
                <div className="flex items-center justify-between mb-6">
                    <h3 className="text-2xl font-bold text-gray-900">Add Service Firm</h3>
                    <button onClick={onClose} className="text-gray-400 hover:text-gray-600"><X size={24} /></button>
                </div>
                <div className="space-y-4">
                    <div>
                        <label className="block text-sm font-medium text-gray-700 mb-2">Firm Name *</label>
                        <input type="text" value={formData.firmaAdi} onChange={(e) => setFormData({...formData, firmaAdi: e.target.value})}
                               className="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 focus:outline-none focus:ring-2 focus:ring-blue-500"
                               placeholder="ABC Service Center" />
                    </div>
                    <div>
                        <label className="block text-sm font-medium text-gray-700 mb-2">Phone</label>
                        <input type="tel" value={formData.telefon} onChange={(e) => setFormData({...formData, telefon: e.target.value})}
                               className="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 focus:outline-none focus:ring-2 focus:ring-blue-500"
                               placeholder="+41 44 123 45 67" />
                    </div>
                    <div>
                        <label className="block text-sm font-medium text-gray-700 mb-2">Email</label>
                        <input type="email" value={formData.email} onChange={(e) => setFormData({...formData, email: e.target.value})}
                               className="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 focus:outline-none focus:ring-2 focus:ring-blue-500"
                               placeholder="contact@firm.ch" />
                    </div>
                    <div>
                        <label className="block text-sm font-medium text-gray-700 mb-2">Address</label>
                        <textarea value={formData.adres} onChange={(e) => setFormData({...formData, adres: e.target.value})} rows="2"
                                  className="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 focus:outline-none focus:ring-2 focus:ring-blue-500 resize-none"
                                  placeholder="Street, City, Postal Code" />
                    </div>
                    <div>
                        <label className="block text-sm font-medium text-gray-700 mb-2">Website</label>
                        <input type="url" value={formData.website} onChange={(e) => setFormData({...formData, website: e.target.value})}
                               className="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 focus:outline-none focus:ring-2 focus:ring-blue-500"
                               placeholder="https://www.firm.ch" />
                    </div>
                    <div>
                        <label className="block text-sm font-medium text-gray-700 mb-2">Notes</label>
                        <textarea value={formData.notlar} onChange={(e) => setFormData({...formData, notlar: e.target.value})} rows="3"
                                  className="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 focus:outline-none focus:ring-2 focus:ring-blue-500 resize-none"
                                  placeholder="Additional notes..." />
                    </div>
                    <div className="flex gap-3 pt-4">
                        <button onClick={onClose} disabled={loading}
                                className="flex-1 px-4 py-3 bg-gray-100 hover:bg-gray-200 text-gray-700 rounded-xl transition-colors font-medium disabled:opacity-50">
                            Cancel
                        </button>
                        <button onClick={handleSubmit} disabled={loading}
                                className="flex-1 px-4 py-3 bg-gradient-to-r from-blue-500 to-blue-600 hover:from-blue-600 hover:to-blue-700 text-white rounded-xl transition-colors shadow-lg shadow-blue-500/30 font-medium disabled:opacity-50">
                            {loading ? 'Adding...' : 'Add Firm'}
                        </button>
                    </div>
                </div>
            </div>
        </div>
    );
}

function ServiceFirmDetailModal({ firm, onClose, onUpdate, addActivity }) {
    const [isEditing, setIsEditing] = useState(false);
    const [editedFirm, setEditedFirm] = useState(firm);
    const [loading, setLoading] = useState(false);

    const handleUpdate = async () => {
        setLoading(true);
        try {
            await updateDoc(doc(db, 'servisFirmalari', firm.id), editedFirm);
            addActivity('Servis Firması Güncellendi', `${firm.firmaAdi} updated`);
            setIsEditing(false);
            onUpdate();
        } catch (error) {
            alert('Failed to update firm');
        } finally {
            setLoading(false);
        }
    };

    return (
        <div className="fixed inset-0 bg-black/30 backdrop-blur-sm flex items-center justify-center p-4 z-50">
            <div className="bg-white rounded-2xl shadow-2xl border border-gray-200 p-6 w-full max-w-2xl">
                <div className="flex items-center justify-between mb-6">
                    <h3 className="text-2xl font-bold text-gray-900">Firm Details</h3>
                    <div className="flex items-center gap-2">
                        <button onClick={() => setIsEditing(!isEditing)}
                                className="px-4 py-2 bg-blue-100 text-blue-700 hover:bg-blue-200 rounded-lg transition-colors flex items-center gap-2">
                            <Edit size={16} />{isEditing ? 'Cancel' : 'Edit'}
                        </button>
                        <button onClick={onClose} className="text-gray-400 hover:text-gray-600"><X size={24} /></button>
                    </div>
                </div>
                {isEditing ? (
                    <div className="space-y-4">
                        <input type="text" value={editedFirm.firmaAdi} onChange={(e) => setEditedFirm({...editedFirm, firmaAdi: e.target.value})}
                               className="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl" placeholder="Firm Name" />
                        <input type="tel" value={editedFirm.telefon || ''} onChange={(e) => setEditedFirm({...editedFirm, telefon: e.target.value})}
                               className="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl" placeholder="Phone" />
                        <input type="email" value={editedFirm.email || ''} onChange={(e) => setEditedFirm({...editedFirm, email: e.target.value})}
                               className="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl" placeholder="Email" />
                        <textarea value={editedFirm.adres || ''} onChange={(e) => setEditedFirm({...editedFirm, adres: e.target.value})} rows="2"
                                  className="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl resize-none" placeholder="Address" />
                        <input type="url" value={editedFirm.website || ''} onChange={(e) => setEditedFirm({...editedFirm, website: e.target.value})}
                               className="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl" placeholder="Website" />
                        <textarea value={editedFirm.notlar || ''} onChange={(e) => setEditedFirm({...editedFirm, notlar: e.target.value})} rows="3"
                                  className="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl resize-none" placeholder="Notes" />
                        <button onClick={handleUpdate} disabled={loading}
                                className="w-full px-4 py-3 bg-gradient-to-r from-blue-500 to-blue-600 hover:from-blue-600 hover:to-blue-700 text-white rounded-xl transition-colors shadow-lg shadow-blue-500/30 font-medium disabled:opacity-50">
                            {loading ? 'Saving...' : 'Save Changes'}
                        </button>
                    </div>
                ) : (
                    <div className="space-y-4">
                        <div className="grid grid-cols-2 gap-4">
                            <div className="col-span-2 p-4 bg-blue-50 rounded-xl border border-blue-200">
                                <p className="text-blue-900 font-bold text-2xl">{firm.firmaAdi}</p>
                            </div>
                            {firm.telefon && (
                                <div className="p-4 bg-gray-50 rounded-xl border border-gray-200">
                                    <p className="text-gray-500 text-sm mb-1">Phone</p>
                                    <p className="text-gray-900 font-semibold flex items-center gap-2">
                                        <Phone size={16} />{firm.telefon}
                                    </p>
                                </div>
                            )}
                            {firm.email && (
                                <div className="p-4 bg-gray-50 rounded-xl border border-gray-200">
                                    <p className="text-gray-500 text-sm mb-1">Email</p>
                                    <p className="text-gray-900 font-semibold flex items-center gap-2 truncate">
                                        <Mail size={16} />{firm.email}
                                    </p>
                                </div>
                            )}
                        </div>
                        {firm.adres && (
                            <div className="p-4 bg-gray-50 rounded-xl border border-gray-200">
                                <p className="text-gray-500 text-sm mb-1">Address</p>
                                <p className="text-gray-900">{firm.adres}</p>
                            </div>
                        )}
                        {firm.website && (
                            <div className="p-4 bg-gray-50 rounded-xl border border-gray-200">
                                <p className="text-gray-500 text-sm mb-1">Website</p>
                                <a href={firm.website} target="_blank" rel="noopener noreferrer"
                                   className="text-blue-600 hover:underline flex items-center gap-2">
                                    <Globe size={16} />{firm.website}
                                </a>
                            </div>
                        )}
                        {firm.notlar && (
                            <div className="p-4 bg-gray-50 rounded-xl border border-gray-200">
                                <p className="text-gray-500 text-sm mb-1">Notes</p>
                                <p className="text-gray-700">{firm.notlar}</p>
                            </div>
                        )}
                    </div>
                )}
            </div>
        </div>
    );
}

// Devam Part 4'te: OfficeOperationsView ve ReportsView

// OFFICE OPERATIONS VIEW
function OfficeOperationsView({ operations, cars, onRefresh, addActivity }) {
    const [showAddModal, setShowAddModal] = useState(false);
    const [selectedType, setSelectedType] = useState('all');
    const [searchQuery, setSearchQuery] = useState('');
    const [dateFilter, setDateFilter] = useState('all');

    const operationTypes = [
        { value: 'Credit Card Receipt', label: 'Credit Card Receipt', icon: CreditCard, color: 'blue' },
        { value: 'POS Daily Closing', label: 'POS Daily Closing', icon: DollarSign, color: 'green' },
        { value: 'Fuel Receipt', label: 'Fuel Receipt', icon: Fuel, color: 'orange' },
        { value: 'Washing Expense', label: 'Washing Expense', icon: Droplet, color: 'cyan' }
    ];

    const filteredOperations = operations.filter(op => {
        const matchesType = selectedType === 'all' || op.type === selectedType;
        const matchesSearch = searchQuery === '' || 
            op.vehiclePlate?.toLowerCase().includes(searchQuery.toLowerCase()) ||
            op.notes?.toLowerCase().includes(searchQuery.toLowerCase());
        
        const now = new Date();
        const opDate = op.date?.seconds ? new Date(op.date.seconds * 1000) : 
                       (typeof op.date === 'number' ? new Date(new Date('2001-01-01T00:00:00Z').getTime() + op.date * 1000) : new Date(op.date));
        let matchesDate = true;
        
        if (dateFilter === 'today') {
            matchesDate = opDate.toDateString() === now.toDateString();
        } else if (dateFilter === 'week') {
            const weekAgo = new Date(now.getTime() - 7 * 24 * 60 * 60 * 1000);
            matchesDate = opDate >= weekAgo;
        } else if (dateFilter === 'month') {
            const monthAgo = new Date(now.getTime() - 30 * 24 * 60 * 60 * 1000);
            matchesDate = opDate >= monthAgo;
        }
        
        return matchesType && matchesSearch && matchesDate;
    });

    const totals = {
        creditCard: operations.filter(op => op.type === 'Credit Card Receipt').reduce((sum, op) => sum + (op.amount || 0), 0),
        pos: operations.filter(op => op.type === 'POS Daily Closing').reduce((sum, op) => sum + (op.amount || 0), 0),
        fuel: operations.filter(op => op.type === 'Fuel Receipt').reduce((sum, op) => sum + (op.amount || 0), 0),
        washing: operations.filter(op => op.type === 'Washing Expense').reduce((sum, op) => sum + (op.amount || 0), 0),
        total: operations.reduce((sum, op) => sum + (op.amount || 0), 0)
    };

    const handleDeleteOperation = async (opId) => {
        if (!window.confirm('Are you sure?')) return;
        try {
            await deleteDoc(doc(db, 'office_operations', opId));
            addActivity('Ofis İşlemi Silindi', 'Office operation deleted');
            onRefresh();
        } catch (error) {
            alert('Failed to delete operation');
        }
    };

    return (
        <div className="space-y-6">
            <div className="flex items-center justify-between gap-4 flex-wrap">
                <div>
                    <h2 className="text-4xl font-bold text-gray-900 flex items-center gap-3">
                        <DollarSign className="text-green-500" size={36} />
                        Office Operations
                    </h2>
                    <p className="text-gray-500 mt-1">Total: {formatCurrency(totals.total)}</p>
                </div>
                <button onClick={() => setShowAddModal(true)}
                        className="flex items-center gap-2 px-6 py-3 bg-gradient-to-r from-green-500 to-green-600 hover:from-green-600 hover:to-green-700 text-white rounded-xl transition-all shadow-lg shadow-green-500/30 font-medium">
                    <Plus size={20} />Add Operation
                </button>
            </div>

            <div className="grid grid-cols-1 md:grid-cols-4 gap-6">
                {operationTypes.map((type) => {
                    const Icon = type.icon;
                    const amount = totals[type.value.toLowerCase().replace(' ', '')];
                    return (
                        <div key={type.value} 
                             className={`bg-gradient-to-br from-${type.color}-50 to-${type.color}-100 rounded-2xl border border-${type.color}-200 p-6 shadow-lg hover:shadow-xl transition-all cursor-pointer ${selectedType === type.value ? 'ring-4 ring-' + type.color + '-400' : ''}`}
                             onClick={() => setSelectedType(selectedType === type.value ? 'all' : type.value)}>
                            <div className="flex items-center gap-3 mb-4">
                                <Icon className={`text-${type.color}-600`} size={24} />
                                <p className={`text-${type.color}-900 font-semibold`}>{type.label}</p>
                            </div>
                            <p className={`text-3xl font-bold text-${type.color}-900`}>{formatCurrency(amount)}</p>
                            <p className={`text-${type.color}-700 text-sm mt-2`}>
                                {operations.filter(op => op.type === type.value).length} operations
                            </p>
                        </div>
                    );
                })}
            </div>

            <div className="bg-white rounded-2xl shadow-lg border border-gray-200 p-6">
                <div className="grid grid-cols-1 md:grid-cols-3 gap-4">
                    <div className="relative">
                        <Search className="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400" size={20} />
                        <input
                            type="text"
                            value={searchQuery}
                            onChange={(e) => setSearchQuery(e.target.value)}
                            placeholder="Search by plate or notes..."
                            className="w-full pl-10 pr-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 focus:outline-none focus:ring-2 focus:ring-green-500"
                        />
                    </div>
                    <select value={dateFilter} onChange={(e) => setDateFilter(e.target.value)}
                            className="px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 focus:outline-none focus:ring-2 focus:ring-green-500">
                        <option value="all">All Time</option>
                        <option value="today">Today</option>
                        <option value="week">This Week</option>
                        <option value="month">This Month</option>
                    </select>
                    <button onClick={() => setSelectedType('all')}
                            className="px-4 py-3 bg-gray-100 hover:bg-gray-200 text-gray-700 rounded-xl transition-colors font-medium">
                        Clear Filters
                    </button>
                </div>
            </div>

            {filteredOperations.length > 0 ? (
                <div className="space-y-4">
                    {filteredOperations.sort((a, b) => {
                        const dateA = a.date?.seconds || 0;
                        const dateB = b.date?.seconds || 0;
                        return dateB - dateA;
                    }).map((operation) => {
                        const typeInfo = operationTypes.find(t => t.value === operation.type);
                        const Icon = typeInfo?.icon || DollarSign;
                        return (
                            <div key={operation.id} className="bg-white rounded-2xl border border-gray-200 p-6 shadow-lg shadow-gray-200/50 hover:shadow-xl transition-all">
                                <div className="flex items-start justify-between">
                                    <div className="flex items-start gap-4 flex-1">
                                        <div className={`w-14 h-14 bg-gradient-to-br from-${typeInfo?.color}-100 to-${typeInfo?.color}-50 rounded-xl flex items-center justify-center`}>
                                            <Icon className={`text-${typeInfo?.color}-600`} size={28} />
                                        </div>
                                        <div className="flex-1">
                                            <div className="flex items-center gap-3 mb-2">
                                                <h3 className="text-lg font-bold text-gray-900">{operation.type}</h3>
                                                <span className="px-3 py-1 bg-green-100 text-green-700 text-sm font-bold rounded-lg">
                                                    {formatCurrency(operation.amount)}
                                                </span>
                                            </div>
                                            <div className="flex items-center gap-4 text-sm text-gray-600">
                                                <span className="flex items-center gap-1">
                                                    <Calendar size={14} />
                                                    {formatDateTime(operation.date)}
                                                </span>
                                                {operation.vehiclePlate && (
                                                    <span className="flex items-center gap-1">
                                                        <Car size={14} />
                                                        {operation.vehiclePlate}
                                                    </span>
                                                )}
                                                {operation.posCount && (
                                                    <span className="flex items-center gap-1 text-green-600 font-semibold">
                                                        <DollarSign size={14} />
                                                        {operation.posCount} POS Terminals
                                                    </span>
                                                )}
                                            </div>
                                            {operation.notes && (
                                                <p className="text-gray-500 text-sm mt-2 p-2 bg-gray-50 rounded-lg">{operation.notes}</p>
                                            )}
                                            {operation.photos && operation.photos.length > 0 && (
                                                <div className="mt-3 flex gap-2">
                                                    {operation.photos.slice(0, 3).map((photo, i) => (
                                                        <img key={i} src={photo} alt="Receipt" className="w-20 h-20 object-cover rounded-lg border border-gray-200" />
                                                    ))}
                                                    {operation.photos.length > 3 && (
                                                        <div className="w-20 h-20 bg-gray-100 rounded-lg border border-gray-200 flex items-center justify-center text-gray-500 font-semibold text-sm">
                                                            +{operation.photos.length - 3}
                                                        </div>
                                                    )}
                                                </div>
                                            )}
                                        </div>
                                    </div>
                                    <button onClick={() => handleDeleteOperation(operation.id)}
                                            className="px-4 py-2 bg-red-100 text-red-700 hover:bg-red-200 rounded-lg transition-colors">
                                        <Trash2 size={16} />
                                    </button>
                                </div>
                            </div>
                        );
                    })}
                </div>
            ) : (
                <div className="text-center py-20 bg-white rounded-2xl border border-gray-200">
                    <DollarSign className="mx-auto text-gray-300 mb-4" size={64} />
                    <h3 className="text-xl font-semibold text-gray-400 mb-2">No Operations Found</h3>
                    <p className="text-gray-500">Try adjusting your filters</p>
                </div>
            )}

            {showAddModal && <AddOfficeOperationModal cars={cars} onClose={() => setShowAddModal(false)} onSuccess={() => { setShowAddModal(false); onRefresh(); }} addActivity={addActivity} />}
        </div>
    );
}

function AddOfficeOperationModal({ cars, onClose, onSuccess, addActivity }) {
    const [formData, setFormData] = useState({
        type: 'Credit Card Receipt',
        amount: '',
        vehiclePlate: '',
        pos1Amount: '',
        pos2Amount: '',
        notes: ''
    });
    const [files, setFiles] = useState([]);
    const [loading, setLoading] = useState(false);

    const operationTypes = ['Credit Card Receipt', 'POS Daily Closing', 'Fuel Receipt', 'Washing Expense'];

    const handleSubmit = async () => {
        if (!formData.type) {
            alert('Please select operation type');
            return;
        }
        if (formData.type === 'POS Daily Closing') {
            if (!formData.pos1Amount && !formData.pos2Amount) {
                alert('Please enter at least one POS amount');
                return;
            }
        } else if (!formData.amount) {
            alert('Please enter amount');
            return;
        }
        
        setLoading(true);
        try {
            const photoURLs = [];
            for (const file of files) {
                const storageRef = ref(storage, `office_operations/${Date.now()}_${file.name}`);
                await uploadBytes(storageRef, file);
                const url = await getDownloadURL(storageRef);
                photoURLs.push(url);
            }
            
            let finalAmount = parseFloat(formData.amount) || 0;
            if (formData.type === 'POS Daily Closing') {
                finalAmount = (parseFloat(formData.pos1Amount) || 0) + (parseFloat(formData.pos2Amount) || 0);
            }
            
            // Convert to iOS TimeInterval format (seconds since 2001-01-01)
            const now = new Date();
            const referenceDateMillis = new Date('2001-01-01T00:00:00Z').getTime();
            const iosTimeInterval = (now.getTime() - referenceDateMillis) / 1000;
            
            await addDoc(collection(db, 'office_operations'), {
                type: formData.type,
                amount: finalAmount,
                vehiclePlate: formData.vehiclePlate || null,
                pos1Amount: formData.type === 'POS Daily Closing' ? (parseFloat(formData.pos1Amount) || 0) : null,
                pos2Amount: formData.type === 'POS Daily Closing' ? (parseFloat(formData.pos2Amount) || 0) : null,
                posCount: formData.type === 'POS Daily Closing' ? 2 : null,
                notes: formData.notes,
                photos: photoURLs,
                date: iosTimeInterval
            });
            addActivity('Ofis İşlemi Eklendi', `${formData.type} operation added`);
            onSuccess();
        } catch (error) {
            console.error('Error:', error);
            alert('Failed to add operation');
        } finally {
            setLoading(false);
        }
    };

    return (
        <div className="fixed inset-0 bg-black/30 backdrop-blur-sm flex items-center justify-center p-4 z-50">
            <div className="bg-white rounded-2xl shadow-2xl border border-gray-200 p-6 w-full max-w-md max-h-[90vh] overflow-y-auto">
                <div className="flex items-center justify-between mb-6">
                    <h3 className="text-2xl font-bold text-gray-900">Add Office Operation</h3>
                    <button onClick={onClose} className="text-gray-400 hover:text-gray-600"><X size={24} /></button>
                </div>
                <div className="space-y-4">
                    <div>
                        <label className="block text-sm font-medium text-gray-700 mb-2">Operation Type *</label>
                        <select value={formData.type} onChange={(e) => setFormData({...formData, type: e.target.value})}
                                className="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 focus:outline-none focus:ring-2 focus:ring-green-500">
                            {operationTypes.map(type => (
                                <option key={type} value={type}>{type}</option>
                            ))}
                        </select>
                    </div>
                    
                    {formData.type !== 'POS Closing' && (
                        <div>
                            <label className="block text-sm font-medium text-gray-700 mb-2">Amount (CHF) *</label>
                            <input type="number" step="0.01" value={formData.amount} onChange={(e) => setFormData({...formData, amount: e.target.value})}
                                   className="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 focus:outline-none focus:ring-2 focus:ring-green-500"
                                   placeholder="0.00" />
                        </div>
                    )}
                    
                    {formData.type === 'POS Daily Closing' && (
                        <div className="space-y-3">
                            <div>
                                <label className="block text-sm font-medium text-gray-700 mb-2">POS 1 Amount (CHF)</label>
                                <input type="number" step="0.01" value={formData.pos1Amount} onChange={(e) => setFormData({...formData, pos1Amount: e.target.value})}
                                       className="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 focus:outline-none focus:ring-2 focus:ring-green-500"
                                       placeholder="0.00" />
                            </div>
                            <div>
                                <label className="block text-sm font-medium text-gray-700 mb-2">POS 2 Amount (CHF)</label>
                                <input type="number" step="0.01" value={formData.pos2Amount} onChange={(e) => setFormData({...formData, pos2Amount: e.target.value})}
                                       className="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 focus:outline-none focus:ring-2 focus:ring-green-500"
                                       placeholder="0.00" />
                            </div>
                        </div>
                    )}
                    
                    {(formData.type === 'Fuel Receipt' || formData.type === 'Washing Expense') && (
                        <div>
                            <label className="block text-sm font-medium text-gray-700 mb-2">Vehicle Plate</label>
                            <input type="text" value={formData.vehiclePlate} onChange={(e) => setFormData({...formData, vehiclePlate: e.target.value})}
                                   list="car-suggestions"
                                   className="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 focus:outline-none focus:ring-2 focus:ring-green-500"
                                   placeholder="ZH 123456" />
                            <datalist id="car-suggestions">
                                {cars.map(car => (
                                    <option key={car.id} value={car.plaka} />
                                ))}
                            </datalist>
                        </div>
                    )}
                    
                    <div>
                        <label className="block text-sm font-medium text-gray-700 mb-2">Notes</label>
                        <textarea value={formData.notes} onChange={(e) => setFormData({...formData, notes: e.target.value})} rows="3"
                                  className="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 focus:outline-none focus:ring-2 focus:ring-green-500 resize-none"
                                  placeholder="Additional notes..." />
                    </div>
                    
                    <div>
                        <label className="block text-sm font-medium text-gray-700 mb-2">Photos</label>
                        <div className="border-2 border-dashed border-gray-300 rounded-xl p-6 text-center hover:border-green-400 transition-colors cursor-pointer">
                            <input type="file" accept="image/*" multiple onChange={(e) => setFiles(Array.from(e.target.files))}
                                   className="hidden" id="op-file-input" />
                            <label htmlFor="op-file-input" className="cursor-pointer">
                                <Upload className="mx-auto text-gray-400 mb-2" size={32} />
                                <p className="text-gray-600 text-sm">Click to upload receipts</p>
                            </label>
                        </div>
                        {files.length > 0 && (
                            <p className="text-sm text-green-600 mt-2 font-medium">{files.length} file(s) selected</p>
                        )}
                    </div>
                    
                    <div className="flex gap-3 pt-4">
                        <button onClick={onClose} disabled={loading}
                                className="flex-1 px-4 py-3 bg-gray-100 hover:bg-gray-200 text-gray-700 rounded-xl transition-colors font-medium disabled:opacity-50">
                            Cancel
                        </button>
                        <button onClick={handleSubmit} disabled={loading}
                                className="flex-1 px-4 py-3 bg-gradient-to-r from-green-500 to-green-600 hover:from-green-600 hover:to-green-700 text-white rounded-xl transition-colors shadow-lg shadow-green-500/30 font-medium disabled:opacity-50">
                            {loading ? 'Adding...' : 'Add Operation'}
                        </button>
                    </div>
                </div>
            </div>
        </div>
    );
}

// REPORTS VIEW
function ReportsView({ cars, returns, officeOperations }) {
    const [reportType, setReportType] = useState('vehicles');
    
    const damagedCars = cars.filter(car => car.hasarKayitlari?.length > 0);
    
    const generateVehicleReport = async (car) => {
        try {
            console.log('Generating vehicle report for:', car.plaka);
            await generateDamagePDF(car);
            console.log('Vehicle report generated successfully');
        } catch (error) {
            console.error('Error generating vehicle report:', error);
            alert('Error generating report: ' + error.message);
        }
    };

    const generateOfficeReport = async () => {
        try {
            console.log('Generating office operations report...');
            await generateOfficePDF(officeOperations);
            console.log('Office report generated successfully');
        } catch (error) {
            console.error('Error generating office report:', error);
            alert('Error generating report: ' + error.message);
        }
    };

    const generateReturnsReport = async () => {
        try {
            console.log('Generating returns report...');
            await generateReturnsPDF(returns);
            console.log('Returns report generated successfully');
        } catch (error) {
            console.error('Error generating returns report:', error);
            alert('Error generating report: ' + error.message);
        }
    };
    
    const oldGenerateOfficeReport = () => {
        const totals = {
            creditCard: officeOperations.filter(op => op.type === 'Credit Card Receipt').reduce((sum, op) => sum + (op.amount || 0), 0),
            pos: officeOperations.filter(op => op.type === 'POS Daily Closing').reduce((sum, op) => sum + (op.amount || 0), 0),
            fuel: officeOperations.filter(op => op.type === 'Fuel Receipt').reduce((sum, op) => sum + (op.amount || 0), 0),
            washing: officeOperations.filter(op => op.type === 'Washing Expense').reduce((sum, op) => sum + (op.amount || 0), 0)
        };
        const total = Object.values(totals).reduce((a, b) => a + b, 0);
        
        const content = `
GREEN MOTION AG - OFFICE OPERATIONS REPORT
=========================================
Generated: ${new Date().toLocaleString()}
Zurich, Switzerland

FINANCIAL SUMMARY
----------------
Total Amount: ${formatCurrency(total)}

Credit Card: ${formatCurrency(totals.creditCard)}
POS Closing: ${formatCurrency(totals.pos)}
Fuel Receipt: ${formatCurrency(totals.fuel)}
Washing: ${formatCurrency(totals.washing)}

DETAILED OPERATIONS
------------------
${officeOperations.sort((a, b) => (b.date?.seconds || 0) - (a.date?.seconds || 0)).map((op, i) => `
${i + 1}. ${op.type}
   Amount: ${formatCurrency(op.amount)}
   Date: ${formatDateTime(op.date)}
   ${op.vehiclePlate ? `Vehicle: ${op.vehiclePlate}` : ''}
   ${op.notes ? `Notes: ${op.notes}` : ''}
   ${op.posCount ? `POS Terminals: ${op.posCount}` : ''}
`).join('\n')}

---
Report generated by Green Motion System
Contact: info@greenmotion.ch
`;
        const blob = new Blob([content], { type: 'text/plain' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = `Office_Operations_Report_${Date.now()}.txt`;
        a.click();
    };

    return (
        <div className="space-y-6">
            <div>
                <h2 className="text-4xl font-bold text-gray-900 flex items-center gap-3">
                    <FileText className="text-blue-500" size={36} />
                    Generate Reports
                </h2>
                <p className="text-gray-500 mt-1">Export data and generate comprehensive reports</p>
            </div>

            <div className="bg-white rounded-2xl shadow-lg border border-gray-200 p-6">
                <div className="flex gap-3">
                    <button onClick={() => setReportType('vehicles')}
                            className={`px-6 py-3 rounded-xl font-medium transition-all ${reportType === 'vehicles' ? 'bg-blue-500 text-white shadow-lg shadow-blue-500/30' : 'bg-gray-100 text-gray-700 hover:bg-gray-200'}`}>
                        Vehicle Reports
                    </button>
                    <button onClick={() => setReportType('office')}
                            className={`px-6 py-3 rounded-xl font-medium transition-all ${reportType === 'office' ? 'bg-green-500 text-white shadow-lg shadow-green-500/30' : 'bg-gray-100 text-gray-700 hover:bg-gray-200'}`}>
                        Office Operations
                    </button>
                    <button onClick={() => setReportType('returns')}
                            className={`px-6 py-3 rounded-xl font-medium transition-all ${reportType === 'returns' ? 'bg-purple-500 text-white shadow-lg shadow-purple-500/30' : 'bg-gray-100 text-gray-700 hover:bg-gray-200'}`}>
                        Returns
                    </button>
                </div>
            </div>

            {reportType === 'vehicles' && (
                <div>
                    <div className="mb-6 bg-blue-50 rounded-2xl p-6 border border-blue-200">
                        <h3 className="text-xl font-bold text-blue-900 mb-2">Vehicle Reports</h3>
                        <p className="text-blue-700">Generate detailed damage reports for each vehicle</p>
                    </div>
                    <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                        {cars.map((car) => (
                            <div key={car.id} className="bg-white rounded-2xl border border-gray-200 p-6 shadow-lg shadow-gray-200/50 hover:shadow-xl transition-all">
                                <div className="flex items-center gap-3 mb-4">
                                    <div className="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center">
                                        <Car className="text-blue-600" size={24} />
                                    </div>
                                    <div>
                                        <h3 className="text-lg font-bold text-gray-900">{car.plaka}</h3>
                                        <p className="text-gray-500 text-sm">{car.marka} {car.model}</p>
                                    </div>
                                </div>
                                <div className="space-y-2 text-sm mb-4">
                                    <div className="flex justify-between">
                                        <span className="text-gray-500">Damages:</span>
                                        <span className={`font-bold ${car.hasarKayitlari?.length > 0 ? 'text-orange-600' : 'text-green-600'}`}>
                                            {car.hasarKayitlari?.length || 0}
                                        </span>
                                    </div>
                                    <div className="flex justify-between">
                                        <span className="text-gray-500">Photos:</span>
                                        <span className="text-gray-900 font-bold">
                                            {car.hasarKayitlari?.reduce((acc, h) => acc + (h.fotograflar?.length || 0), 0) || 0}
                                        </span>
                                    </div>
                                </div>
                                <button onClick={() => generateVehicleReport(car)}
                                        className="w-full flex items-center justify-center gap-2 px-4 py-3 bg-gradient-to-r from-blue-500 to-blue-600 hover:from-blue-600 hover:to-blue-700 text-white rounded-xl transition-all shadow-lg shadow-blue-500/30 font-medium">
                                    <Download size={18} />
                                    Generate Report
                                </button>
                            </div>
                        ))}
                    </div>
                </div>
            )}

            {reportType === 'office' && (
                <div>
                    <div className="mb-6 bg-green-50 rounded-2xl p-6 border border-green-200">
                        <h3 className="text-xl font-bold text-green-900 mb-2">Office Operations Report</h3>
                        <p className="text-green-700">Comprehensive financial overview of all office operations</p>
                    </div>
                    <div className="bg-white rounded-2xl border border-gray-200 p-8 shadow-lg text-center">
                        <DollarSign className="mx-auto text-green-500 mb-4" size={64} />
                        <h3 className="text-3xl font-bold text-gray-900 mb-2">
                            {formatCurrency(officeOperations.reduce((sum, op) => sum + (op.amount || 0), 0))}
                        </h3>
                        <p className="text-gray-500 mb-6">Total from {officeOperations.length} operations</p>
                        <button onClick={generateOfficeReport}
                                className="px-8 py-4 bg-gradient-to-r from-green-500 to-green-600 hover:from-green-600 hover:to-green-700 text-white rounded-xl transition-all shadow-lg shadow-green-500/30 font-medium flex items-center gap-3 mx-auto">
                            <FileSpreadsheet size={20} />
                            Generate Full Report
                        </button>
                    </div>
                </div>
            )}

            {reportType === 'returns' && (
                <div>
                    <div className="mb-6 bg-purple-50 rounded-2xl p-6 border border-purple-200">
                        <h3 className="text-xl font-bold text-purple-900 mb-2">Returns Report</h3>
                        <p className="text-purple-700">Complete overview of all vehicle returns</p>
                    </div>
                    <div className="bg-white rounded-2xl border border-gray-200 p-8 shadow-lg text-center">
                        <ArrowLeft className="mx-auto text-purple-500 mb-4" size={64} />
                        <h3 className="text-3xl font-bold text-gray-900 mb-2">{returns.length}</h3>
                        <p className="text-gray-500 mb-6">Total returns processed</p>
                        <button onClick={generateReturnsReport}
                                className="px-8 py-4 bg-gradient-to-r from-purple-500 to-purple-600 hover:from-purple-600 hover:to-purple-700 text-white rounded-xl transition-all shadow-lg shadow-purple-500/30 font-medium flex items-center gap-3 mx-auto">
                            <Printer size={20} />
                            Generate Full Report
                        </button>
                    </div>
                </div>
            )}
        </div>
    );
}

// Component'lerin sonu - tüm uygulama tamamlandı!
